@import './styles/theme.wxss';

/* 全局 CSS 变量与重置 (无主题时的兜底值) */
page {
  --bg: #1a1412;
  --surface: #261d19;
  --card: #302621;
  --accent1: #cda869;
  --accent2: #658266;
  --accent3: #b85440;
  --accent4: #6b5c7d;
  --text: #e8ded1;
  --text-sub: #9e8e7c;
  --border: rgba(212, 175, 111, 0.15);
  --green: #71985a;
  --radius: 16px;

  background-color: #F8F6F0;
  color: var(--text);
  font-family: -apple-system, 'PingFang SC', 'Hiragino Sans GB', sans-serif;
  box-sizing: border-box;
}

.app-shell {
  height: 100vh;
  background-color: var(--bg);
  display: flex;
  flex-direction: column;
  box-sizing: border-box;
}

view, text, scroll-view, image {
  box-sizing: border-box;
}

/* 隐藏滚动条 */
::-webkit-scrollbar {
  display: none;
  width: 0;
  height: 0;
  color: transparent;
}

/* 全局底部安全区占位：自定义 TabBar (120rpx) + iOS 安全区 */
.tabbar-safe-spacer {
  height: calc(120rpx + env(safe-area-inset-bottom));
  width: 100%;
  flex-shrink: 0;
  background: transparent;
}
