<view class="chat-container app-shell" data-theme="{{currentTheme}}">
  <view class="sub-nav">
    <view class="sub-nav-pill {{currentTab === 'chat' ? 'active' : ''}}" bindtap="switchTab" data-tab="chat">💬 问诊</view>
    <view class="sub-nav-pill {{currentTab === 'story' ? 'active' : ''}}" bindtap="goToAdventure">📖 奇遇记</view>
    <view class="sub-nav-pill {{currentTab === 'quiz' ? 'active' : ''}}" bindtap="switchTab" data-tab="quiz">🎯 脑洞答题</view>
    <view class="sub-nav-pill {{currentTab === 'dungeon' ? 'active' : ''}}" bindtap="switchTab" data-tab="dungeon">🗺️ 现世秘境</view>
  </view>

  <!-- 问诊对话 -->
  <block wx:if="{{currentTab === 'chat'}}">
    <scroll-view scroll-y class="chat-scroll" scroll-into-view="{{scrollToId}}" scroll-with-animation>
      <view class="chat-content">
        <block wx:for="{{msgList}}" wx:key="id">
          <view class="msg-row {{item.role === 'user' ? 'msg-user' : 'msg-ai'}}">
            <view class="avatar">{{item.role === 'user' ? '我' : '佗'}}</view>
            <view class="msg-bubble">
              <view wx:if="{{item.typing}}" class="ai-typing">
                <view class="typing-dot"></view>
                <view class="typing-dot"></view>
                <view class="typing-dot"></view>
              </view>
              <view wx:elif="{{item.segments}}" class="msg-formatted">
                <block wx:for="{{item.segments}}" wx:key="*this" wx:for-item="seg">
                  <view wx:if="{{seg.type === 'heading'}}" class="msg-heading">
                    <text wx:for="{{seg.inlines}}" wx:key="*this" wx:for-item="part" class="{{part.style === 'b' ? 'msg-bold' : ''}}">{{part.text}}</text>
                  </view>
                  <view wx:elif="{{seg.type === 'list'}}" class="msg-list-item">
                    <text class="msg-bullet">• </text>
                    <text wx:for="{{seg.inlines}}" wx:key="*this" wx:for-item="part" class="{{part.style === 'b' ? 'msg-bold' : ''}}">{{part.text}}</text>
                  </view>
                  <view wx:elif="{{seg.type === 'list-num'}}" class="msg-list-item">
                    <text class="msg-num">{{seg.num}}. </text>
                    <text wx:for="{{seg.inlines}}" wx:key="*this" wx:for-item="part" class="{{part.style === 'b' ? 'msg-bold' : ''}}">{{part.text}}</text>
                  </view>
                  <view wx:elif="{{seg.type === 'spacer'}}" class="msg-spacer"></view>
                  <text wx:else class="msg-text">
                    <text wx:for="{{seg.inlines}}" wx:key="*this" wx:for-item="part" class="{{part.style === 'b' ? 'msg-bold' : ''}}">{{part.text}}</text>
                  </text>
                </block>
              </view>
              <text wx:else>{{item.content}}</text>
            </view>
          </view>
        </block>
        <view id="scroll-bottom" style="height: 40rpx;"></view>
      </view>
    </scroll-view>
    <view class="quick-qs">
      <text class="quick-q" bindtap="askQuick" data-text="我熬夜怎么调理？">熬夜调理</text>
      <text class="quick-q" bindtap="askQuick" data-text="我脾胃不好吃什么？">脾胃调养</text>
      <text class="quick-q" bindtap="askQuick" data-text="春季养生怎么做？">春季养生</text>
      <text class="quick-q" bindtap="askQuick" data-text="亳菊有什么功效？">亳菊功效</text>
      <text class="quick-q" bindtap="askQuick" data-text="五禽戏怎么练？">五禽戏</text>
    </view>
    <view class="input-area">
      <view class="voice-btn {{recording ? 'recording' : ''}}" bindtouchstart="startRecord" bindtouchend="stopRecord">
        <text>{{recording ? '■' : '🎤'}}</text>
      </view>
      <input class="chat-input" value="{{inputValue}}" bindinput="onInput" placeholder="询问养生建议..." confirm-type="send" bindconfirm="sendMessage"/>
      <button class="send-btn" bindtap="sendMessage">发送</button>
    </view>
  </block>

  <!-- 脑洞答题 -->
  <scroll-view scroll-y class="chat-scroll" wx:if="{{currentTab === 'quiz'}}">
    <view class="sub-content">
      <view class="hero hero-teal fade-in">
        <view class="hero-badge">🎯 脑洞大挑战</view>
        <view class="hero-title">养生<text class="highlight">冷知识</text>答题对战</view>
      </view>

      <view class="quiz-card fade-in">
        <!-- 加载中 -->
        <view wx:if="{{brainLoading}}" class="quiz-status">正在加载题目...</view>

        <!-- 未开始 -->
        <view wx:elif="{{brainQuestions.length === 0 && !brainResult}}" class="quiz-status">
          <view class="quiz-start-btn" bindtap="loadBrainQuestions">🎯 开始答题</view>
        </view>

        <!-- 结算结果 -->
        <view wx:elif="{{brainResult}}" class="quiz-result">
          <view class="quiz-result-icon">{{brainResult.total_correct >= 4 ? '🎉' : (brainResult.total_correct >= 2 ? '👍' : '💪')}}</view>
          <view class="quiz-result-score">{{brainResult.total_correct}}<text class="quiz-result-total">/{{brainResult.total_questions}}</text></view>
          <view class="quiz-result-energy">+{{brainResult.earned_energy}} 元气值</view>
          <view class="quiz-detail-list">
            <view class="quiz-detail-item {{item.is_correct ? 'right' : 'wrong'}}"
                  wx:for="{{brainResult.details}}" wx:key="question_id">
              <view class="quiz-detail-q">{{item.content}}</view>
              <view class="quiz-detail-ans">你的答案: {{item.user_answer}} | 正确答案: {{item.correct_answer}}</view>
            </view>
          </view>
          <view class="quiz-retry-btn" bindtap="resetBrainQuiz">🔄 再来一局</view>
        </view>

        <!-- 答题中 -->
        <view wx:else>
          <view class="quiz-header">
            <text class="quiz-progress">第 {{brainCurrentIdx + 1}} / {{brainQuestions.length}} 题</text>
            <view class="quiz-bar-bg"><view class="quiz-bar-fill" style="width:{{(brainCurrentIdx / brainQuestions.length) * 100}}%"></view></view>
          </view>
          <view class="quiz-q">{{brainQuestions[brainCurrentIdx].content}}</view>
          <view class="quiz-options">
            <view class="quiz-opt"
                  wx:for="{{brainQuestions[brainCurrentIdx].options}}" wx:key="key" wx:for-index="idx"
                  bindtap="brainAnswer" data-idx="{{idx}}">
              <text class="quiz-opt-key">{{item.key}}</text>
              <text>{{item.text}}</text>
            </view>
          </view>
        </view>
      </view>

      <view class="game-grid fade-in">
        <view class="game-card" bindtap="placeholderTap" data-msg="好友对战功能开发中">
          <view class="game-card-icon">👥</view>
          <view class="game-card-name">好友对战</view>
          <view class="game-card-desc">邀请好友同时答题竞速</view>
          <view class="game-hot-badge">热</view>
        </view>
        <view class="game-card" bindtap="placeholderTap" data-msg="排行榜功能开发中">
          <view class="game-card-icon">🏅</view>
          <view class="game-card-name">今日排行</view>
          <view class="game-card-desc">元气值榜单兑换专属茶方</view>
        </view>
      </view>
    </view>
  </scroll-view>

  <!-- 现世秘境（LBS 景点打卡） -->
  <block wx:if="{{currentTab === 'dungeon'}}">
    <view class="map-wrap">
      <map
        id="landmarkMap"
        class="landmark-map"
        longitude="{{centerLng}}"
        latitude="{{centerLat}}"
        scale="{{mapScale}}"
        markers="{{markers}}"
        bindmarkertap="onMarkerTap"
        bindcallouttap="onMarkerTap"
        enable-poi="{{false}}"
        enable-building="{{false}}"
        enable-traffic="{{false}}"
        show-compass="{{false}}"
        show-scale="{{false}}"
        enable-rotate="{{false}}"
        enable-overlooking="{{false}}"
      ></map>
    </view>

    <!-- 半屏模态框 -->
    <view class="lbs-modal-mask" wx:if="{{showModal}}" bindtap="closeModal" catchtouchmove="preventScroll">
      <view class="lbs-modal" catchtap="preventBubble">
        <view class="lbs-modal-img" style="background-image: url({{activeLandmark.bg_img}})">
          <view class="lbs-modal-overlay"></view>
          <view class="close-btn" bindtap="closeModal">✕</view>
          <view class="lbs-modal-title">{{activeLandmark.name}}</view>
        </view>
        <view class="lbs-modal-body">
          <!-- 线下打卡卡片 -->
          <view class="action-card card-offline" hover-class="card-press" bindtap="onCheckin">
            <view class="card-header">
              <text class="card-title">📍 亲临寻迹</text>
              <text class="card-badge">超高收益</text>
            </view>
            <view class="card-desc">需本人与景区特定指示牌合影</view>
            <view class="card-tags">
              <text class="reward-tag tag-ssr">SSR级药材</text>
              <text class="reward-tag tag-ssr">实体文创</text>
              <text class="reward-tag tag-ssr">景区门票</text>
            </view>
          </view>

          <!-- 神游古迹卡片 -->
          <view class="action-card card-online" hover-class="card-press" bindtap="onQuiz">
            <view class="card-header">
              <text class="card-title">📜 神游古迹</text>
            </view>
            <view class="card-desc">吾身虽远，心向往之。消耗 20 灵力</view>
            <view class="card-tags">
              <text class="reward-tag tag-normal">随机药材</text>
              <text class="reward-tag tag-normal">灵力回血</text>
            </view>
          </view>
        </view>
      </view>
    </view>
  </block>
</view>
