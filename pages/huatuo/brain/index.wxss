.app-shell { height: auto; display: block; }
.scroll-content {
  min-height: 100vh;
  background: var(--bg);
}

.hero {
  margin: 24rpx;
  border-radius: var(--radius);
  background: var(--card);
  border: 2rpx solid var(--border);
  padding: 40rpx 36rpx 32rpx;
}
.hero-teal { border-color: rgba(107,203,119,0.3); }
.hero-badge {
  display: inline-block;
  background: var(--accent1);
  color: #0f0f18;
  font-size: 20rpx;
  font-weight: 700;
  padding: 4rpx 20rpx;
  border-radius: 40rpx;
  margin-bottom: 20rpx;
}
.hero-title { font-size: 44rpx; font-weight: 800; line-height: 1.3; }
.highlight { color: var(--accent1); }
.hero-subtitle { font-size: 24rpx; color: var(--text-sub); margin-top: 12rpx; }

.mode-list { padding: 0 24rpx; }

.mode-card {
  display: flex;
  align-items: center;
  gap: 20rpx;
  background: var(--card);
  border: 2rpx solid var(--border);
  border-radius: var(--radius);
  padding: 32rpx 24rpx;
  margin-bottom: 20rpx;
  transition: all 0.2s;
}
.mode-card:active { transform: scale(0.97); }
.mode-card.solo { border-color: rgba(107,203,119,0.3); }
.mode-card.battle { border-color: rgba(232,56,56,0.3); }

.mode-icon { font-size: 56rpx; flex-shrink: 0; }
.mode-info { flex: 1; min-width: 0; }
.mode-name { font-size: 30rpx; font-weight: 700; margin-bottom: 8rpx; }
.mode-desc { font-size: 22rpx; color: var(--text-sub); }
.mode-arrow { font-size: 36rpx; color: var(--text-sub); flex-shrink: 0; }

.tip-card {
  display: flex;
  align-items: flex-start;
  gap: 16rpx;
  margin: 32rpx 24rpx;
  padding: 24rpx;
  background: rgba(232,168,56,0.08);
  border: 2rpx solid rgba(232,168,56,0.2);
  border-radius: var(--radius);
}
.tip-icon { font-size: 36rpx; flex-shrink: 0; }
.tip-text { font-size: 24rpx; color: var(--text-sub); line-height: 1.5; }
