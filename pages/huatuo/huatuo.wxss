.chat-container { height: 100vh; display: flex; flex-direction: column; background: var(--bg); }

/* ===== 子导航 ===== */
.sub-nav {
  display: flex;
  justify-content: space-around;
  padding: 20rpx 24rpx;
  background: var(--card);
  border-bottom: 2rpx solid var(--border);
  position: sticky;
  top: 0;
  z-index: 10;
  flex-shrink: 0;
}
.sub-nav-pill {
  font-size: 24rpx;
  color: var(--text-sub);
  padding: 10rpx 20rpx;
  border-radius: 30rpx;
  transition: all 0.3s;
}
.sub-nav-pill.active {
  background: rgba(232, 168, 56, 0.15);
  color: var(--accent1);
  font-weight: bold;
}

/* ===== 问诊对话 ===== */
.chat-header { padding: 16rpx 24rpx 8rpx; background: var(--surface); border-bottom: 1rpx solid var(--border); flex-shrink: 0; }
.chat-header-left { display: flex; align-items: center; gap: 10rpx; }
.chat-header-icon { font-size: 36rpx; }
.chat-header-info { display: flex; flex-direction: column; }
.chat-header-name { font-size: 26rpx; font-weight: 700; color: var(--text); }
.chat-header-status { font-size: 20rpx; color: var(--green); }

.chat-scroll { flex: 1; overflow-y: hidden; }
.chat-content { padding: 30rpx 24rpx; padding-bottom: 20rpx; }
.msg-row { display: flex; margin-bottom: 40rpx; align-items: flex-start; }
.msg-user { flex-direction: row-reverse; }
.avatar {
  width: 72rpx; height: 72rpx; border-radius: 50%; margin: 0 20rpx;
  display: flex; align-items: center; justify-content: center;
  font-weight: bold; font-size: 28rpx; flex-shrink: 0;
}
.msg-ai .avatar { background: linear-gradient(135deg, var(--surface), var(--card)); color: var(--accent1); border: 2rpx solid var(--border); }
.msg-user .avatar { background: var(--accent1); color: #0f0f18; }
.msg-bubble {
  max-width: 65%; padding: 20rpx 28rpx; font-size: 28rpx; line-height: 1.6;
  word-wrap: break-word; border-radius: var(--radius);
}
.msg-ai .msg-bubble { background: var(--surface); color: var(--text); border-top-left-radius: 4rpx; border: 2rpx solid var(--border); }
.msg-user .msg-bubble { background: var(--accent2); color: #0f0f18; border-top-right-radius: 4rpx; }

/* 格式化消息 */
.msg-formatted { line-height: 1.8; }
.msg-heading {
  font-size: 30rpx; font-weight: 800; margin-bottom: 8rpx; padding-bottom: 8rpx;
  border-bottom: 2rpx solid var(--border);
}
.msg-bold { font-weight: 800; color: var(--accent1); }
.msg-list-item { margin: 4rpx 0; padding-left: 8rpx; }
.msg-bullet { color: var(--accent2); }
.msg-num { color: var(--accent2); }
.msg-spacer { height: 16rpx; }
.msg-text { line-height: 1.8; }

.quick-tags-wrap { padding: 12rpx 0 20rpx 0; }
.quick-tags-scroll {
  width: 100%;
  white-space: nowrap;
  padding-left: 24rpx;
  box-sizing: border-box;
}
.tag-item {
  display: inline-flex; align-items: center; justify-content: center;
  height: 52rpx; padding: 0 26rpx; margin-right: 16rpx;
  font-size: 24rpx; border-radius: 60rpx;
  background: rgba(0, 0, 0, 0.03); color: #6A6157;
  border: 1rpx solid rgba(0, 0, 0, 0.04);
}
.tag-item.tag-primary {
  background: #C38B3A; color: #FFFFFF; border: none; font-weight: 500;
  box-shadow: none;
}

/* 打字动画 */
.ai-typing { display: flex; align-items: center; gap: 8rpx; padding: 12rpx 8rpx; }
.typing-dot {
  width: 12rpx; height: 12rpx; border-radius: 50%;
  background: var(--accent1);
  animation: typingBounce 1.4s ease infinite;
}
.typing-dot:nth-child(2) { animation-delay: 0.2s; }
.typing-dot:nth-child(3) { animation-delay: 0.4s; }
@keyframes typingBounce {
  0%, 60%, 100% { opacity: 0.3; transform: translateY(0); }
  30% { opacity: 1; transform: translateY(-8rpx); }
}

/* 语音按钮 */
.voice-btn {
  width: 72rpx; height: 72rpx; border-radius: 50%;
  background: var(--card); border: 2rpx solid var(--border);
  display: flex; align-items: center; justify-content: center;
  font-size: 28rpx; margin-right: 12rpx; flex-shrink: 0;
  transition: all 0.15s;
}
.voice-btn.recording { background: var(--accent3); border-color: var(--accent3); animation: voicePulse 0.8s ease infinite; }
@keyframes voicePulse { 0%, 100% { box-shadow: 0 0 0 0 rgba(255,107,157,0.4); } 50% { box-shadow: 0 0 0 16rpx rgba(255,107,157,0); } }

.input-area {
  display: flex; align-items: center; justify-content: space-between;
  width: 100%; box-sizing: border-box;
  padding: 16rpx 24rpx;
  padding-bottom: calc(16rpx + 110rpx + env(safe-area-inset-bottom));
  background: var(--card); border-top: 2rpx solid var(--border); flex-shrink: 0;
}
.chat-input {
  flex: 1 !important; height: 72rpx; margin: 0 20rpx;
  background: var(--bg); border-radius: 40rpx; padding: 0 24rpx;
  font-size: 28rpx; color: var(--text);
}
.send-btn {
  width: 140rpx !important; flex: 0 0 140rpx !important;
  height: 64rpx !important;
  padding: 0 !important; margin: 0 !important;
  display: flex !important; align-items: center !important; justify-content: center !important;
  font-size: 26rpx !important; font-weight: 500;
  border-radius: 64rpx !important; background: #C38B3A !important; color: #FFFFFF !important;
  line-height: normal !important; box-sizing: border-box;
}
.send-btn::after { display: none !important; }

/* ===== 通用子页面 ===== */
.sub-content { padding: 0 24rpx 160rpx; }

/* ===== Hero 变体 ===== */
.hero {
  margin: 20rpx 0 16rpx; border-radius: var(--radius);
  background: var(--card);
  padding: 32rpx 28rpx 24rpx; position: relative; overflow: hidden;
}
.hero-purple { background: var(--card); }
.hero-teal { background: var(--card); }
.hero-gold { background: var(--card); }
.hero-badge {
  display: inline-block; background: var(--accent1); color: #0f0f18;
  font-size: 20rpx; font-weight: 700; padding: 4rpx 20rpx; border-radius: 40rpx; margin-bottom: 16rpx;
}
.hero-title { font-size: 44rpx; font-weight: 800; line-height: 1.3; }
.highlight { color: var(--accent1); }
.hero-subtitle { font-size: 24rpx; color: var(--text-sub); margin-top: 10rpx; }

/* ===== 奇遇记 ===== */
.story-card {
  background: var(--card);
  border-radius: var(--radius); padding: 28rpx; border: 2rpx solid var(--border); margin-bottom: 16rpx;
}
.story-chapter { font-size: 24rpx; color: var(--accent4); font-weight: 700; margin-bottom: 14rpx; }
.story-text { font-size: 26rpx; line-height: 1.8; color: var(--text); margin-bottom: 20rpx; }
.story-options { display: flex; flex-direction: column; gap: 12rpx; }
.story-opt {
  padding: 18rpx 20rpx; background: var(--surface); border: 2rpx solid var(--border);
  border-radius: 16rpx; font-size: 24rpx; transition: all 0.2s;
}
.story-opt:active { background: rgba(168,85,247,0.12); border-color: var(--accent4); }

.progress-card {
  display: flex; align-items: center; gap: 16rpx;
  background: var(--card); border-radius: var(--radius); padding: 24rpx;
  border: 2rpx solid var(--border);
}
.progress-icon { font-size: 44rpx; }
.progress-info { flex: 1; }
.progress-title { font-size: 26rpx; font-weight: 700; }
.progress-sub { font-size: 20rpx; color: var(--text-sub); margin-top: 4rpx; }
.progress-num { font-size: 36rpx; font-weight: 800; color: var(--accent4); }

/* ===== 脑洞答题入口 ===== */
.game-grid { display: flex; flex-direction: column; gap: 12rpx; margin-bottom: 20rpx; }
.game-card {
  background: var(--card); border-radius: var(--radius); padding: 24rpx 20rpx;
  border: 2rpx solid var(--border); position: relative; overflow: hidden;
}
.game-card:active { transform: scale(0.96); }
.game-card-icon { font-size: 48rpx; margin-bottom: 12rpx; }
.game-card-name { font-size: 26rpx; font-weight: 700; margin-bottom: 6rpx; }
.game-card-desc { font-size: 20rpx; color: var(--text-sub); line-height: 1.5; }
.game-hot-badge {
  position: absolute; top: 12rpx; right: 12rpx;
  background: var(--accent3); color: white; font-size: 18rpx;
  padding: 2rpx 12rpx; border-radius: 20rpx; font-weight: 700;
}

/* ===== 现世秘境（景点卡片流）===== */
.landmark-scroll {
  flex: 1;
  background: #F4F6F5;
  padding: 24rpx 24rpx 0;
}

.landmark-card {
  position: relative;
  width: 100%;
  height: 400rpx;
  border-radius: 24rpx;
  margin-bottom: 32rpx;
  overflow: hidden;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.08);
}

.landmark-img {
  width: 100%;
  height: 100%;
  filter: blur(1.5px);
  transform: scale(1.1);
}

.landmark-overlay {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  height: 60%;
  background: linear-gradient(to bottom, transparent, rgba(0, 0, 0, 0.8));
  pointer-events: none;
}

.landmark-info {
  position: absolute;
  left: 28rpx;
  bottom: 28rpx;
  right: 28rpx;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.landmark-name {
  font-size: 44rpx;
  font-weight: bold;
  color: #fff;
  text-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.5);
}

.landmark-sub {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.7);
}

/* 半屏模态框 */
.lbs-modal-mask {
  position: fixed;
  inset: 0;
  z-index: 1000;
  background: rgba(10, 10, 20, 0.7);
  backdrop-filter: blur(8rpx);
  display: flex;
  align-items: flex-end;
}

.lbs-modal {
  width: 100%;
  height: 75vh;
  background: var(--surface);
  border-radius: 40rpx 40rpx 0 0;
  display: flex;
  flex-direction: column;
  overflow: hidden;
  animation: modalSlideUp 0.3s ease;
}

@keyframes modalSlideUp {
  from { transform: translateY(100%); }
  to { transform: translateY(0); }
}

.lbs-modal-img {
  height: 35%;
  position: relative;
  display: flex;
  align-items: flex-end;
  flex-shrink: 0;
  overflow: hidden;
}

.lbs-modal-bg {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
  filter: blur(1.5px);
  transform: scale(1.1);
}

.lbs-modal-overlay {
  position: absolute;
  inset: 0;
  background: linear-gradient(to bottom, transparent 20%, rgba(0,0,0,0.55) 65%, rgba(0,0,0,0.85));
}

.close-btn {
  position: absolute;
  top: 24rpx;
  right: 24rpx;
  z-index: 2;
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  background: rgba(0,0,0,0.45);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  color: #fff;
  line-height: 1;
  font-weight: 300;
}

.lbs-modal-title {
  position: relative;
  z-index: 1;
  color: #fff;
  font-size: 40rpx;
  font-weight: 800;
  padding: 0 36rpx 24rpx;
  text-shadow: 0 2rpx 12rpx rgba(0,0,0,0.6);
  letter-spacing: 4rpx;
}

.lbs-modal-body {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: center;
  padding: 24rpx 36rpx;
  padding-bottom: calc(24rpx + 120rpx + env(safe-area-inset-bottom));
  gap: 40rpx;
}

/* ===== 富信息动作卡片 ===== */
.action-card {
  padding: 24rpx;
  border-radius: 16rpx;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  transition: all 0.15s;
}

/* 线下：暖金渐变 */
.card-offline {
  background: linear-gradient(135deg, #F3E7D8 0%, #E6D0B3 100%);
  border: 2rpx solid #D2B48C;
  position: relative;
  overflow: hidden;
}

.offline-reminder {
  position: absolute;
  right: 28rpx;
  top: 50%;
  transform: translateY(-50%) rotate(12deg);
  font-size: 36rpx;
  font-weight: 800;
  color: rgba(184, 115, 51, 0.3);
  letter-spacing: 8rpx;
  pointer-events: none;
  white-space: nowrap;
  border: 3rpx solid rgba(184, 115, 51, 0.25);
  border-radius: 12rpx;
  padding: 12rpx 24rpx;
}

/* 线上：虚线虚化 */
.card-online {
  background: rgba(255,255,255,0.8);
  border: 2rpx dashed #C8B9A6;
}

.card-press {
  transform: scale(0.97);
  opacity: 0.85;
}

.card-header {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.card-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #5C3A21;
}

.card-badge {
  font-size: 20rpx;
  font-weight: 700;
  color: #B87333;
  background: rgba(184,115,51,0.15);
  padding: 2rpx 14rpx;
  border-radius: 20rpx;
  border: 1rpx solid rgba(184,115,51,0.3);
}

.card-desc {
  font-size: 22rpx;
  color: #8B7355;
  line-height: 1.5;
}

.card-tags {
  display: flex;
  flex-direction: row;
  flex-wrap: wrap;
  gap: 12rpx;
}

.reward-tag {
  font-size: 22rpx;
  font-weight: 600;
  padding: 4rpx 16rpx;
  border-radius: 8rpx;
  background: rgba(255,255,255,0.7);
  border: 1rpx solid rgba(92,58,33,0.15);
}

.tag-ssr {
  color: #b85440;
  border-color: rgba(184,84,64,0.25);
}

.tag-normal {
  color: #8B7355;
}

.ssc-privilege-tag {
  font-size: 22rpx;
  font-weight: 600;
  padding: 4rpx 16rpx;
  border-radius: 8rpx;
  color: #1B5299;
  background: rgba(27, 82, 153, 0.06);
  border: 1rpx solid rgba(27, 82, 153, 0.25);
}

.open-box-btn {
  color: #0f0f18; border-radius: 24rpx; font-size: 28rpx; font-weight: 800;
  height: 80rpx; line-height: 1; padding: 0;
  display: flex; align-items: center; justify-content: center;
}

.fade-in { animation: fadeIn .4s ease both; }
@keyframes fadeIn { from { opacity: 0; transform: translateY(10px); } to { opacity: 1; transform: translateY(0); } }

/* ===== 体质缺失引导弹窗 ===== */
.physique-modal-mask {
  position: fixed; inset: 0; z-index: 1100;
  background: rgba(0,0,0,0.55);
  display: flex; align-items: center; justify-content: center;
}
.physique-modal {
  width: 560rpx; background: var(--surface); border-radius: 24rpx;
  padding: 48rpx 36rpx 32rpx; text-align: center;
  animation: fadeIn .3s ease both;
}
.physique-modal-title {
  font-size: 34rpx; font-weight: 800; color: var(--text); margin-bottom: 20rpx;
}
.physique-modal-body {
  font-size: 26rpx; color: var(--text-sub); line-height: 1.8; margin-bottom: 36rpx;
}
.physique-modal-actions { display: flex; gap: 20rpx; }
.physique-btn-cancel {
  flex: 1; height: 80rpx; line-height: 80rpx; font-size: 26rpx;
  background: var(--card); color: var(--text-sub); border-radius: 40rpx;
  border: 2rpx solid var(--border); padding: 0;
}
.physique-btn-go {
  flex: 1; height: 80rpx; line-height: 80rpx; font-size: 26rpx; font-weight: 700;
  background: var(--accent1); color: #1a1412; border-radius: 40rpx;
  border: none; padding: 0;
}

.tip-card {
  display: flex;
  align-items: flex-start;
  gap: 16rpx;
  margin: 32rpx 24rpx;
  padding: 24rpx;
  background: rgba(232,168,56,0.08);
  border: 2rpx solid rgba(232,168,56,0.2);
  border-radius: var(--radius);
}
.tip-icon { font-size: 36rpx; flex-shrink: 0; }
.tip-text { font-size: 24rpx; color: var(--text-sub); line-height: 1.5; }
