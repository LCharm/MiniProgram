.chat-container { height: 100vh; display: flex; flex-direction: column; background: var(--bg); }

/* ===== 子导航 ===== */
.sub-nav {
  display: flex;
  gap: 6px;
  padding: 12px 12px 0;
  background: var(--bg);
  flex-shrink: 0;
}
.sub-nav-pill {
  flex: 1;
  text-align: center;
  padding: 10px 0;
  background: var(--card);
  border: 2rpx solid var(--border);
  border-radius: 40rpx;
  font-size: 22rpx;
  color: var(--text-sub);
  transition: all 0.2s;
}
.sub-nav-pill.active { background: rgba(232,168,56,0.12); border-color: var(--accent1); color: var(--accent1); }

/* ===== 问诊对话 ===== */
.chat-scroll { flex: 1; overflow-y: hidden; }
.chat-content { padding: 30rpx 24rpx; padding-bottom: 20rpx; }
.msg-row { display: flex; margin-bottom: 40rpx; align-items: flex-start; }
.msg-user { flex-direction: row-reverse; }
.avatar {
  width: 72rpx; height: 72rpx; border-radius: 50%; margin: 0 20rpx;
  display: flex; align-items: center; justify-content: center;
  font-weight: bold; font-size: 28rpx; flex-shrink: 0;
}
.msg-ai .avatar { background: linear-gradient(135deg, var(--surface), var(--card)); color: var(--accent1); border: 2rpx solid var(--border); }
.msg-user .avatar { background: var(--accent1); color: #0f0f18; }
.msg-bubble {
  max-width: 65%; padding: 20rpx 28rpx; font-size: 28rpx; line-height: 1.6;
  word-wrap: break-word; border-radius: var(--radius);
}
.msg-ai .msg-bubble { background: var(--surface); color: var(--text); border-top-left-radius: 4rpx; border: 2rpx solid var(--border); }
.msg-user .msg-bubble { background: var(--accent2); color: #0f0f18; border-top-right-radius: 4rpx; }

/* 格式化消息 */
.msg-formatted { line-height: 1.8; }
.msg-heading {
  font-size: 30rpx; font-weight: 800; margin-bottom: 8rpx; padding-bottom: 8rpx;
  border-bottom: 2rpx solid var(--border);
}
.msg-bold { font-weight: 800; color: var(--accent1); }
.msg-list-item { margin: 4rpx 0; padding-left: 8rpx; }
.msg-bullet { color: var(--accent2); }
.msg-num { color: var(--accent2); }
.msg-spacer { height: 16rpx; }
.msg-text { line-height: 1.8; }

.quick-qs {
  display: flex; gap: 8px; padding: 0 24rpx 12rpx; overflow-x: auto; flex-shrink: 0;
  white-space: nowrap;
}
.quick-q {
  flex-shrink: 0; padding: 8rpx 20rpx; background: var(--card); border: 2rpx solid var(--border);
  border-radius: 40rpx; font-size: 22rpx; color: var(--text-sub); transition: all 0.2s;
}
.quick-q:active { border-color: var(--accent1); color: var(--accent1); }

/* 打字动画 */
.ai-typing { display: flex; align-items: center; gap: 8rpx; padding: 12rpx 8rpx; }
.typing-dot {
  width: 12rpx; height: 12rpx; border-radius: 50%;
  background: var(--accent1);
  animation: typingBounce 1.4s ease infinite;
}
.typing-dot:nth-child(2) { animation-delay: 0.2s; }
.typing-dot:nth-child(3) { animation-delay: 0.4s; }
@keyframes typingBounce {
  0%, 60%, 100% { opacity: 0.3; transform: translateY(0); }
  30% { opacity: 1; transform: translateY(-8rpx); }
}

/* 语音按钮 */
.voice-btn {
  width: 72rpx; height: 72rpx; border-radius: 50%;
  background: var(--card); border: 2rpx solid var(--border);
  display: flex; align-items: center; justify-content: center;
  font-size: 28rpx; margin-right: 12rpx; flex-shrink: 0;
  transition: all 0.15s;
}
.voice-btn.recording { background: var(--accent3); border-color: var(--accent3); animation: voicePulse 0.8s ease infinite; }
@keyframes voicePulse { 0%, 100% { box-shadow: 0 0 0 0 rgba(255,107,157,0.4); } 50% { box-shadow: 0 0 0 16rpx rgba(255,107,157,0); } }

.input-area {
  display: flex; align-items: center; padding: 16rpx 24rpx;
  padding-bottom: calc(16rpx + 110rpx + env(safe-area-inset-bottom));
  background: var(--card); border-top: 2rpx solid var(--border); flex-shrink: 0;
}
.chat-input {
  flex: 1; height: 80rpx; background: var(--bg); border-radius: 40rpx;
  padding: 0 32rpx; font-size: 28rpx; color: var(--text);
}
.send-btn {
  margin-left: 24rpx; width: 140rpx !important; height: 80rpx; line-height: 1;
  background: var(--accent1); color: #0f0f18; font-weight: 800; border-radius: 40rpx;
  padding: 0; font-size: 28rpx;
  display: flex; align-items: center; justify-content: center;
}

/* ===== 通用子页面 ===== */
.sub-content { padding: 0 24rpx 160rpx; }

/* ===== Hero 变体 ===== */
.hero {
  margin: 20rpx 0 16rpx; border-radius: var(--radius);
  background: var(--card);
  padding: 32rpx 28rpx 24rpx; position: relative; overflow: hidden;
}
.hero-purple { background: var(--card); }
.hero-teal { background: var(--card); }
.hero-gold { background: var(--card); }
.hero-badge {
  display: inline-block; background: var(--accent1); color: #0f0f18;
  font-size: 20rpx; font-weight: 700; padding: 4rpx 20rpx; border-radius: 40rpx; margin-bottom: 16rpx;
}
.hero-title { font-size: 44rpx; font-weight: 800; line-height: 1.3; }
.highlight { color: var(--accent1); }
.hero-subtitle { font-size: 24rpx; color: var(--text-sub); margin-top: 10rpx; }

/* ===== 奇遇记 ===== */
.story-card {
  background: var(--card);
  border-radius: var(--radius); padding: 28rpx; border: 2rpx solid var(--border); margin-bottom: 16rpx;
}
.story-chapter { font-size: 24rpx; color: var(--accent4); font-weight: 700; margin-bottom: 14rpx; }
.story-text { font-size: 26rpx; line-height: 1.8; color: var(--text); margin-bottom: 20rpx; }
.story-options { display: flex; flex-direction: column; gap: 12rpx; }
.story-opt {
  padding: 18rpx 20rpx; background: var(--surface); border: 2rpx solid var(--border);
  border-radius: 16rpx; font-size: 24rpx; transition: all 0.2s;
}
.story-opt:active { background: rgba(168,85,247,0.12); border-color: var(--accent4); }

.progress-card {
  display: flex; align-items: center; gap: 16rpx;
  background: var(--card); border-radius: var(--radius); padding: 24rpx;
  border: 2rpx solid var(--border);
}
.progress-icon { font-size: 44rpx; }
.progress-info { flex: 1; }
.progress-title { font-size: 26rpx; font-weight: 700; }
.progress-sub { font-size: 20rpx; color: var(--text-sub); margin-top: 4rpx; }
.progress-num { font-size: 36rpx; font-weight: 800; color: var(--accent4); }

/* ===== 脑洞答题 ===== */
.quiz-card {
  background: var(--card); border-radius: var(--radius); padding: 28rpx;
  border: 2rpx solid var(--border); margin-bottom: 16rpx;
}
.quiz-header { margin-bottom: 20rpx; }
.quiz-energy { font-size: 22rpx; color: var(--accent2); font-weight: 700; }
.quiz-bar-bg { height: 8rpx; background: var(--border); border-radius: 8rpx; margin-top: 10rpx; overflow: hidden; }
.quiz-bar-fill { height: 100%; border-radius: 8rpx; background: linear-gradient(90deg, var(--accent2), var(--green)); transition: width 0.4s; }
.quiz-q { font-size: 28rpx; font-weight: 600; line-height: 1.6; margin-bottom: 20rpx; }
.quiz-options { display: flex; flex-direction: column; gap: 12rpx; }
.quiz-opt {
  padding: 18rpx 20rpx; background: var(--surface); border: 2rpx solid var(--border);
  border-radius: 16rpx; font-size: 24rpx; transition: all 0.2s;
}
.quiz-opt.right { background: rgba(107,203,119,0.15); border-color: var(--green); }
.quiz-opt.wrong { background: rgba(255,107,157,0.15); border-color: var(--accent3); }

.game-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 12rpx; margin-bottom: 20rpx; }
.game-card {
  background: var(--card); border-radius: var(--radius); padding: 24rpx 20rpx;
  border: 2rpx solid var(--border); position: relative; overflow: hidden;
}
.game-card:active { transform: scale(0.96); }
.game-card-icon { font-size: 48rpx; margin-bottom: 12rpx; }
.game-card-name { font-size: 26rpx; font-weight: 700; margin-bottom: 6rpx; }
.game-card-desc { font-size: 20rpx; color: var(--text-sub); line-height: 1.5; }
.game-hot-badge {
  position: absolute; top: 12rpx; right: 12rpx;
  background: var(--accent3); color: white; font-size: 18rpx;
  padding: 2rpx 12rpx; border-radius: 20rpx; font-weight: 700;
}

/* ===== 修行闯关 ===== */
.dungeon-map {
  background: var(--card); border-radius: var(--radius); padding: 28rpx;
  border: 2rpx solid var(--border); margin-bottom: 16rpx;
}
.dungeon-title { font-size: 26rpx; font-weight: 800; margin-bottom: 24rpx; }
.stages-row { display: flex; justify-content: space-between; align-items: flex-start; position: relative; }
.stages-row::before {
  content: '';
  position: absolute;
  top: 32rpx; left: 8%; width: 84%; height: 2rpx;
  background: linear-gradient(90deg, var(--accent1) 40%, var(--border) 40%);
  z-index: 0;
}
.stage-node { display: flex; flex-direction: column; align-items: center; gap: 8rpx; position: relative; z-index: 1; text-align: center; }
.stage-circle {
  width: 64rpx; height: 64rpx; border-radius: 50%;
  display: flex; align-items: center; justify-content: center;
  font-size: 28rpx; border: 3rpx solid var(--border); background: var(--surface);
  transition: all 0.3s;
}
.stage-node.unlocked .stage-circle { border-color: var(--accent1); background: rgba(232,168,56,0.1); }
.stage-node.current .stage-circle {
  border-color: var(--accent2); background: rgba(78,205,196,0.1);
  box-shadow: 0 0 20rpx rgba(78,205,196,0.4);
  animation: stagePulse 2s ease infinite;
}
@keyframes stagePulse {
  0%, 100% { box-shadow: 0 0 20rpx rgba(78,205,196,0.4); }
  50% { box-shadow: 0 0 35rpx rgba(78,205,196,0.7); }
}
.stage-node.locked .stage-circle { opacity: 0.4; }
.stage-name { font-size: 18rpx; color: var(--text-sub); max-width: 80rpx; }
.stage-node.current .stage-name { color: var(--accent2); font-weight: 700; }

.battle-card {
  background: var(--card);
  border-radius: var(--radius); padding: 28rpx;
  border: 2rpx solid var(--border); margin-bottom: 16rpx;
}
.battle-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 16rpx; }
.battle-tag { font-size: 22rpx; background: rgba(168,85,247,0.2); color: var(--accent4); padding: 4rpx 16rpx; border-radius: 20rpx; font-weight: 700; }
.battle-live { font-size: 20rpx; color: var(--accent3); display: flex; align-items: center; gap: 6rpx; }
.live-dot { width: 12rpx; height: 12rpx; border-radius: 50%; background: var(--accent3); animation: blink 1s ease infinite; }
@keyframes blink { 0%, 100% { opacity: 1; } 50% { opacity: 0.3; } }
.battle-desc { font-size: 24rpx; color: var(--text); line-height: 1.6; margin-bottom: 12rpx; }
.battle-rewards { font-size: 22rpx; color: var(--accent1); }

.open-box-btn {
  color: #0f0f18; border-radius: 24rpx; font-size: 28rpx; font-weight: 800;
  height: 80rpx; line-height: 1; padding: 0;
  display: flex; align-items: center; justify-content: center;
}

.stats-mini { display: flex; background: var(--card); border-radius: var(--radius); border: 2rpx solid var(--border); overflow: hidden; }
.stat-mini-item {
  flex: 1; padding: 24rpx 12rpx; text-align: center;
  border-right: 2rpx solid var(--border);
}
.stat-mini-item:last-child { border-right: none; }
.stat-mini-val { font-size: 36rpx; font-weight: 800; color: var(--accent1); }
.stat-mini-label { font-size: 20rpx; color: var(--text-sub); margin-top: 4rpx; }

.fade-in { animation: fadeIn .4s ease both; }
@keyframes fadeIn { from { opacity: 0; transform: translateY(10px); } to { opacity: 1; transform: translateY(0); } }
