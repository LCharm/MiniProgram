/* pages/user/cardBook/cardBook.wxss */

.app-shell { height: auto; display: block; }
.scroll-content {
  min-height: 100vh;
  background: var(--bg);
}

/* 头部进度 */
.book-header { margin: 16rpx; padding: 24rpx; background: var(--card); border-radius: 16rpx; border: 2rpx solid var(--border); }
.book-title { font-size: 28rpx; font-weight: 700; margin-bottom: 12rpx; }
.book-progress { font-size: 22rpx; color: var(--text-sub); margin-bottom: 10rpx; }
.book-bar-bg { height: 8rpx; background: var(--border); border-radius: 8rpx; overflow: hidden; }
.book-bar-fill { height: 100%; border-radius: 8rpx; background: linear-gradient(90deg, var(--accent2), var(--green)); transition: width 0.4s; }

/* 筛选行 */
.filter-row { display: flex; gap: 12rpx; padding: 0 16rpx 12rpx; }
.filter-btn {
  padding: 10rpx 28rpx; font-size: 22rpx; font-weight: 600;
  background: var(--card); border: 2rpx solid var(--border); border-radius: 24rpx; color: var(--text-sub);
}
.filter-btn.active { background: var(--accent2); color: #fff; border-color: var(--accent2); }

.loading-text { text-align: center; padding: 80rpx 0; color: var(--text-sub); font-size: 24rpx; }

/* --- 卡片网格布局 --- */
.card-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 20rpx;
  padding: 0 24rpx;
}

/* --- 卡片主容器 --- */
.card-item {
  background: var(--card);
  border-radius: 20rpx;
  padding: 30rpx 20rpx;
  border: 2rpx solid var(--border);
  position: relative;

  display: flex;
  flex-direction: column;
  align-items: center;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.02);
}

.card-item.rare {
  border-color: var(--accent2);
}

/* --- 正方形大图视觉中心 --- */
.card-img {
  width: 210rpx;
  height: 210rpx;
  margin-bottom: 20rpx;
  display: block;
  border-radius: 12rpx;
}

/* --- 状态控制 --- */
.card-item.herb-unlocked {
  filter: none;
  opacity: 1;
}

.card-item.herb-locked {
  opacity: 0.75;
  filter: grayscale(100%);
  transition: all 0.3s ease;
}

/* --- 徽章与角标 --- */
.card-tier-badge {
  position: absolute;
  top: 16rpx;
  left: 16rpx;
  font-size: 20rpx;
  font-weight: bold;
  color: var(--accent2);
  background: rgba(232, 168, 56, 0.15);
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
}

/* --- 数量角标 --- */
.card-qty-badge {
  position: absolute;
  top: 16rpx;
  right: 16rpx;
  font-size: 20rpx;
  font-weight: 900;
  color: #fff;
  background: #4ecdc4;
  padding: 4rpx 12rpx;
  border-radius: 20rpx 8rpx 20rpx 8rpx;
  box-shadow: 0 4rpx 8rpx rgba(0,0,0,0.1);
  z-index: 2;
}

.card-unlocked-mark {
  font-size: 24rpx;
  color: var(--text-sub);
  font-weight: normal;
  margin-top: 8rpx;
}

.card-tips {
  font-size: 24rpx;
  color: var(--text-sub);
  margin-top: 4rpx;
  line-height: 1.4;
}
