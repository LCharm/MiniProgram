/* pages/user/cardBook/cardBook.wxss */

.scroll-content {
  height: 100vh;
  background: var(--bg);
}

/* 头部进度 */
.book-header { margin: 16rpx; padding: 24rpx; background: var(--card); border-radius: 16rpx; border: 2rpx solid var(--border); }
.book-title { font-size: 28rpx; font-weight: 700; margin-bottom: 12rpx; }
.book-progress { font-size: 22rpx; color: var(--text-sub); margin-bottom: 10rpx; }
.book-bar-bg { height: 8rpx; background: var(--border); border-radius: 8rpx; overflow: hidden; }
.book-bar-fill { height: 100%; border-radius: 8rpx; background: linear-gradient(90deg, var(--accent2), var(--green)); transition: width 0.4s; }

/* 筛选行 */
.filter-row { display: flex; gap: 12rpx; padding: 0 16rpx 12rpx; }
.filter-btn {
  padding: 10rpx 28rpx; font-size: 22rpx; font-weight: 600;
  background: var(--card); border: 2rpx solid var(--border); border-radius: 24rpx; color: var(--text-sub);
}
.filter-btn.active { background: var(--accent2); color: #fff; border-color: var(--accent2); }

.loading-text { text-align: center; padding: 80rpx 0; color: var(--text-sub); font-size: 24rpx; }

/* 卡牌网格 */
.card-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 12rpx; padding: 0 16rpx; }
.card-item {
  background: var(--card); border-radius: 16rpx; padding: 20rpx 12rpx;
  border: 2rpx solid var(--border); position: relative; text-align: center; overflow: hidden;
}
.card-item.rare { border-color: var(--accent2); }
.card-item.herb-unlocked { filter: none; opacity: 1; }
.card-item.herb-locked {
  filter: grayscale(100%);
  opacity: 0.4;
  transition: all 0.3s ease;
}

.card-tier-badge {
  position: absolute; top: 8rpx; left: 8rpx;
  font-size: 18rpx; font-weight: 700; color: var(--accent2);
  background: rgba(232,168,56,0.15); padding: 2rpx 10rpx; border-radius: 10rpx;
}
.card-qty-badge {
  position: absolute; top: 8rpx; right: 10rpx;
  font-size: 20rpx; font-weight: 700; color: var(--accent2);
}
.card-img { width: 80rpx; height: 80rpx; margin: 0 auto 8rpx; }
.card-emoji { font-size: 48rpx; margin-bottom: 8rpx; }
.card-name { font-size: 26rpx; font-weight: 700; margin-bottom: 4rpx; }
.card-label { font-size: 20rpx; color: var(--text-sub); margin-bottom: 6rpx; }
.card-tips { font-size: 18rpx; color: var(--accent2); margin-top: 4rpx; }
.card-unlocked-mark { font-size: 20rpx; color: var(--green); font-weight: 600; margin-top: 4rpx; }
