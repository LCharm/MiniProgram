<view class="app-shell" data-theme="{{currentTheme}}">
  <scroll-view scroll-y class="scroll-content">

    <!-- 收集进度 -->
    <view class="book-header fade-in">
      <view class="book-title">百草药材图鉴</view>
      <view class="book-progress">已集齐 {{unlockedCount}} / {{totalCount}}</view>
      <view class="book-bar-bg"><view class="book-bar-fill" style="width:{{unlockedCount / totalCount * 100}}%"></view></view>
    </view>

    <!-- 筛选 -->
    <view class="filter-row fade-in">
      <view class="filter-btn {{filter === 'all' ? 'active' : ''}}" bindtap="switchFilter" data-filter="all">全部</view>
      <view class="filter-btn {{filter === 'unlocked' ? 'active' : ''}}" bindtap="switchFilter" data-filter="unlocked">已解锁</view>
      <view class="filter-btn {{filter === 'locked' ? 'active' : ''}}" bindtap="switchFilter" data-filter="locked">未解锁</view>
    </view>

    <view wx:if="{{loading}}" class="loading-text">加载中...</view>

    <view wx:else class="card-grid fade-in">
      <view class="card-item {{item.is_unlocked ? 'herb-unlocked' : 'herb-locked'}} {{item.tier === 'rare' ? 'rare' : ''}}"
            wx:for="{{cards}}" wx:key="item_id"
            wx:if="{{filter === 'all' || (filter === 'unlocked' && item.is_unlocked) || (filter === 'locked' && !item.is_unlocked)}}"
            bindtap="onCardTap" data-item-id="{{item.item_id}}" data-quantity="{{item.quantity}}">
        <view class="card-tier-badge" wx:if="{{item.tier === 'rare'}}">稀有</view>
        <view class="card-qty-badge" wx:if="{{item.is_unlocked && item.quantity > 0}}">{{item.quantity}}</view>
        <image class="card-img" src="{{item.icon_url}}" mode="aspectFit" wx:if="{{item.icon_url}}"></image>
        <image class="card-img" src="/images/herbs/{{item.item_id}}.png" mode="aspectFit" wx:else></image>
        <view class="card-tips" wx:if="{{!item.is_unlocked && item.unlock_tips}}">{{item.unlock_tips}}</view>
        <view class="card-unlocked-mark" wx:elif="{{item.is_unlocked}}">已解锁</view>
      </view>
    </view>

  </scroll-view>
</view>
