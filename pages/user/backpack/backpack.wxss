/* pages/user/backpack/backpack.wxss */

.app-shell { height: auto; display: block; }

/* 药材锁定/解锁滤镜 */
.herb-unlocked { filter: none; opacity: 1; }
.herb-locked {
  filter: grayscale(100%);
  opacity: 0.4;
  transition: all 0.3s ease;
}

.scroll-content {
  min-height: 100vh;
  background: var(--bg);
}

/* 子标签 */
.sub-tabs { display: flex; margin: 16rpx; background: var(--card); border-radius: 12rpx; padding: 6rpx; gap: 4rpx; }
.sub-tab { flex: 1; text-align: center; padding: 14rpx 0; font-size: 24rpx; font-weight: 600; color: var(--text-sub); border-radius: 10rpx; transition: all 0.2s; }
.sub-tab.active { background: var(--accent2); color: #fff; }
.sub-tab-count { font-weight: 400; font-size: 20rpx; }

.loading-text { text-align: center; padding: 80rpx 0; color: var(--text-sub); font-size: 24rpx; }
.empty-tip { text-align: center; padding: 80rpx 32rpx; color: var(--text-sub); font-size: 26rpx; }

/* 药材网格 */
.backpack-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 12rpx; padding: 0 16rpx; }
.backpack-card {
  background: var(--card); border-radius: 16rpx; padding: 24rpx 16rpx;
  border: 2rpx solid var(--border); position: relative; text-align: center;
}
.backpack-card.rare { border-color: var(--accent2); background: linear-gradient(135deg, rgba(232,168,56,0.06), var(--card)); }
.bp-card-icon { width: 210rpx; height: 210rpx; margin: 0 auto 12rpx; border-radius: 12rpx; display: block; }
.bp-card-name { font-size: 26rpx; font-weight: 700; margin-bottom: 4rpx; }
.bp-card-desc { font-size: 20rpx; color: var(--text-sub); margin-bottom: 8rpx; }
.bp-card-qty {
  position: absolute; top: 12rpx; right: 16rpx;
  font-size: 22rpx; font-weight: 700; color: var(--accent2);
}

/* 列表样式 (卡券/道具) */
.backpack-list { padding: 0 16rpx; }
.bp-list-item {
  display: flex; align-items: center; gap: 16rpx;
  background: var(--card); border-radius: 16rpx; padding: 20rpx;
  border: 2rpx solid var(--border); margin-bottom: 10rpx;
}
.bp-list-emoji { font-size: 44rpx; flex-shrink: 0; }
.bp-list-info { flex: 1; min-width: 0; }
.bp-list-name { font-size: 26rpx; font-weight: 700; margin-bottom: 4rpx; color: var(--text); }
.bp-list-desc { font-size: 22rpx; color: var(--text-sub); margin-bottom: 2rpx; }
.bp-list-date { font-size: 20rpx; color: var(--text-sub); opacity: 0.7; }
.bp-list-qty { font-size: 24rpx; font-weight: 700; color: var(--accent2); }

/* 成品茶饮 & 兑换按钮 */
.bp-list-item.brewed-tea {
  border-color: var(--accent2);
  background: linear-gradient(135deg, rgba(232,168,56,0.08), var(--card));
}
.redeem-btn {
  font-size: 22rpx; padding: 10rpx 24rpx; border-radius: 24rpx;
  background: var(--accent1); color: #fff; border: none;
  line-height: 1.4; flex-shrink: 0;
}

/* 兑换 Modal */
.redeem-overlay {
  position: fixed; top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0.55); z-index: 1000;
  display: flex; align-items: center; justify-content: center;
}
.redeem-modal {
  width: 620rpx; background: var(--card); border-radius: 24rpx;
  padding: 40rpx 36rpx 32rpx;
  box-shadow: 0 12rpx 48rpx rgba(0,0,0,0.2);
}
.redeem-modal-title {
  font-size: 32rpx; font-weight: 700; text-align: center; margin-bottom: 8rpx;
  color: var(--text);
}
.redeem-item-name {
  text-align: center; font-size: 24rpx; color: var(--accent2);
  margin-bottom: 28rpx; font-weight: 600;
}
.redeem-form { display: flex; flex-direction: column; gap: 16rpx; }
.redeem-input {
  width: 100%; height: 80rpx; padding: 0 20rpx;
  background: var(--surface); border-radius: 12rpx;
  border: 2rpx solid var(--border); font-size: 26rpx;
  box-sizing: border-box; color: var(--text);
}
.redeem-textarea {
  width: 100%; height: 140rpx; padding: 16rpx 20rpx;
  background: var(--surface); border-radius: 12rpx;
  border: 2rpx solid var(--border); font-size: 26rpx;
  box-sizing: border-box; color: var(--text);
}
.redeem-actions {
  display: flex; gap: 20rpx; margin-top: 32rpx;
}
.redeem-cancel {
  flex: 1; height: 80rpx; line-height: 80rpx; text-align: center;
  background: var(--bg); border-radius: 40rpx; font-size: 28rpx; font-weight: 600;
  color: var(--text-sub); border: 2rpx solid var(--border);
}
.redeem-confirm {
  flex: 1; height: 80rpx; line-height: 80rpx; text-align: center;
  background: var(--accent1); border-radius: 40rpx; font-size: 28rpx; font-weight: 600;
  color: #fff; border: none;
}
