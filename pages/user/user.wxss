.scroll-content {
  height: 100vh;
  padding-bottom: 200rpx;
  background: var(--bg);
}

/* ================================================
   1. 顶部 Hero 渐变区
   ================================================ */
.profile-hero {
  position: relative;
  margin: 0;
  padding: 60rpx 32rpx 80rpx;
  background: linear-gradient(180deg, #2d1b4e 0%, #1e1a38 40%, #16162a 100%);
  border-radius: 0 0 60rpx 60rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
  overflow: hidden;
}

/* 右上角会员角标 */
.vip-corner {
  position: absolute;
  top: 24rpx;
  right: 28rpx;
  font-size: 18rpx;
  color: rgba(255, 255, 255, 0.45);
  background: rgba(255, 255, 255, 0.08);
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
  letter-spacing: 1rpx;
  transition: all 0.4s ease;
}

/* 会员激活态：金色发光 */
.vip-corner.vip-active {
  color: #0f0f18;
  background: linear-gradient(135deg, #e8a838, #f5c842);
  font-weight: 700;
  letter-spacing: 2rpx;
  box-shadow: 0 0 16rpx rgba(232, 168, 56, 0.5), 0 0 40rpx rgba(232, 168, 56, 0.2);
  animation: vipGlow 2s ease-in-out infinite;
}

@keyframes vipGlow {
  0%, 100% {
    box-shadow: 0 0 16rpx rgba(232, 168, 56, 0.5), 0 0 40rpx rgba(232, 168, 56, 0.2);
  }
  50% {
    box-shadow: 0 0 24rpx rgba(232, 168, 56, 0.7), 0 0 56rpx rgba(232, 168, 56, 0.35);
  }
}

/* ── 头像 ── */
.hero-avatar {
  position: relative;
  width: 140rpx;
  height: 140rpx;
  margin-bottom: 24rpx;
}

.avatar-img {
  width: 140rpx;
  height: 140rpx;
  border-radius: 50%;
  overflow: hidden;
}

.avatar-empty {
  width: 140rpx;
  height: 140rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.06);
  border: 3rpx solid rgba(255, 255, 255, 0.15);
}

/* 金色光环 */
.avatar-ring {
  position: absolute;
  inset: -6rpx;
  border-radius: 50%;
  border: 3rpx solid rgba(232, 168, 56, 0.5);
  box-shadow: 0 0 20rpx rgba(232, 168, 56, 0.25), inset 0 0 12rpx rgba(232, 168, 56, 0.1);
  pointer-events: none;
}

/* ── 昵称 ── */
.hero-name {
  font-size: 38rpx;
  font-weight: 800;
  color: #f0e8d8;
  letter-spacing: 3rpx;
  margin-bottom: 16rpx;
}

.hero-name-dim {
  opacity: 0.6;
}

.hero-sub {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.5);
  margin-bottom: 20rpx;
}

/* ── 体质玉牌（已测定）── */
.physical-seal {
  display: inline-flex;
  align-items: center;
  gap: 10rpx;
  background: rgba(232, 168, 56, 0.12);
  border: 2rpx solid rgba(232, 168, 56, 0.35);
  border-radius: 12rpx;
  padding: 10rpx 28rpx;
  position: relative;
}

.physical-seal::before {
  content: '';
  position: absolute;
  inset: -4rpx;
  border-radius: 14rpx;
  border: 1rpx solid rgba(232, 168, 56, 0.15);
  pointer-events: none;
}

.seal-emoji {
  font-size: 30rpx;
}

.seal-text {
  font-size: 26rpx;
  font-weight: 700;
  color: #e8a838;
  letter-spacing: 3rpx;
}

/* ── 体质 CTA（未测评，脉冲动画）── */
.physical-cta {
  display: inline-flex;
  align-items: center;
  padding: 12rpx 32rpx;
  background: rgba(255, 255, 255, 0.08);
  backdrop-filter: blur(10rpx);
  border: 2rpx solid rgba(255, 255, 255, 0.2);
  border-radius: 40rpx;
  animation: ctaPulse 2s ease-in-out infinite;
}

@keyframes ctaPulse {
  0%, 100% {
    border-color: rgba(255, 255, 255, 0.2);
    box-shadow: 0 0 0 0 rgba(232, 168, 56, 0);
  }
  50% {
    border-color: rgba(232, 168, 56, 0.5);
    box-shadow: 0 0 24rpx rgba(232, 168, 56, 0.25);
  }
}

.cta-text {
  font-size: 26rpx;
  font-weight: 600;
  color: rgba(255, 255, 255, 0.85);
  letter-spacing: 2rpx;
}

/* ── 未登录 ── */
.hero-login {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.login-btn {
  margin-top: 8rpx;
  padding: 12rpx 36rpx;
  font-size: 24rpx;
  background: var(--accent1);
  color: #fff;
  border-radius: 40rpx;
  border: none;
  font-weight: 700;
  letter-spacing: 2rpx;
}

.login-btn::after {
  border: none;
}

/* ================================================
   2. 悬浮数值面板
   ================================================ */
.stats-float {
  margin: -36rpx 24rpx 28rpx;
  padding: 28rpx 8rpx;
  background: var(--card);
  border-radius: var(--radius);
  border: 2rpx solid var(--border);
  display: flex;
  align-items: center;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.3);
  position: relative;
  z-index: 2;
}

.stat-item {
  flex: 1;
  text-align: center;
  padding: 0 4rpx;
}

.stat-num {
  font-size: 40rpx;
  font-weight: 900;
  color: var(--text);
  margin-bottom: 6rpx;
  line-height: 1.1;
}

.accent-gold {
  color: var(--accent1);
}

.accent-green {
  color: var(--accent2);
}

.stat-label {
  font-size: 20rpx;
  color: var(--text-sub);
}

.stat-divider {
  width: 1rpx;
  height: 56rpx;
  background: var(--border);
  flex-shrink: 0;
}

/* ================================================
   3. 菜单列表（保持不变）
   ================================================ */
.menu-list {
  margin: 0 24rpx;
  background: var(--card);
  border-radius: var(--radius);
  padding: 0 32rpx;
}

.menu-item {
  display: flex;
  align-items: center;
  padding: 32rpx 0;
  border-bottom: 2rpx solid var(--border);
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-icon {
  font-size: 36rpx;
  width: 56rpx;
  text-align: center;
  flex-shrink: 0;
}

.menu-text {
  flex: 1;
  font-size: 28rpx;
  color: var(--text);
  margin-left: 24rpx;
}

.menu-badge {
  background: rgba(232, 168, 56, 0.15);
  color: var(--accent1);
  font-size: 20rpx;
  padding: 2rpx 12rpx;
  border-radius: 20rpx;
  white-space: nowrap;
  flex-shrink: 0;
  margin-right: 12rpx;
}

.menu-badge.highlight {
  background: rgba(232, 168, 56, 0.2);
  color: var(--accent1);
  font-weight: 700;
}

.menu-arrow {
  color: var(--text-sub);
  font-size: 32rpx;
  flex-shrink: 0;
}

/* ===== 通用动画 ===== */
.fade-in {
  animation: fadeIn 0.4s ease both;
}

@keyframes fadeIn {
  from { opacity: 0; transform: translateY(10rpx); }
  to { opacity: 1; transform: translateY(0); }
}
