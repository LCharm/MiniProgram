.scroll-content {
  height: 100vh;
  padding-bottom: 200rpx;
  background: var(--bg, #0f0f18);
}

.profile-card {
  margin: 32rpx 24rpx;
  padding: 40rpx 32rpx;
  background: var(--surface);
  border-radius: var(--radius);
  border: 2rpx solid var(--border);
  display: flex;
  justify-content: space-between;
  align-items: center;
}
.avatar-area {
  display: flex;
  align-items: center;
  gap: 24rpx;
}
.avatar-real {
  width: 100rpx; height: 100rpx;
  border-radius: 50%;
  border: 4rpx solid var(--accent1);
  overflow: hidden;
}
.avatar-placeholder {
  width: 100rpx; height: 100rpx;
  border-radius: 50%;
  background: var(--surface);
  border: 4rpx solid var(--accent1);
}
.nickname {
  font-size: 36rpx;
  font-weight: 800;
  color: var(--text);
  letter-spacing: 4rpx;
  white-space: nowrap;
}
.user-physical {
  display: inline-block;
  font-size: 22rpx;
  color: var(--accent1);
  background: rgba(232,168,56,0.12);
  padding: 4rpx 20rpx;
  border-radius: 20rpx;
  margin-top: 10rpx;
  font-weight: 600;
}
.member-badge {
  flex-shrink: 0;
  font-size: 20rpx;
  background: linear-gradient(135deg, var(--accent1), var(--accent1));
  color: #0f0f18;
  padding: 10rpx 22rpx;
  border-radius: 24rpx;
  font-weight: 700;
  align-self: flex-end;
}
.login-btn {
  margin: 0;
  background: var(--accent1);
  color: #0f0f18;
  font-size: 24rpx;
  font-weight: 700;
  padding: 0 32rpx;
  height: 64rpx;
  line-height: 1;
  border-radius: 32rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.stats-board {
  margin: 0 24rpx 32rpx;
  background: var(--card);
  border-radius: var(--radius);
  display: flex;
  align-items: center;
  padding: 32rpx 0;
}
.stat-box {
  flex: 1;
  text-align: center;
}
.stat-val {
  font-size: 36rpx;
  font-weight: 800;
  color: var(--text);
  margin-bottom: 8rpx;
}
.highlight { color: var(--accent1); }
.highlight-green { color: var(--accent2); }
.stat-name {
  font-size: 22rpx;
  color: var(--text-sub);
}
.divider {
  width: 2rpx;
  height: 60rpx;
  background: var(--border);
}

.menu-list {
  margin: 0 24rpx;
  background: var(--card);
  border-radius: var(--radius);
  padding: 0 32rpx;
}
.menu-item {
  display: flex;
  align-items: center;
  padding: 32rpx 0;
  border-bottom: 2rpx solid var(--border);
}
.menu-item:last-child { border-bottom: none; }
.menu-icon { font-size: 36rpx; width: 56rpx; text-align: center; flex-shrink: 0; }
.menu-text { flex: 1; font-size: 28rpx; color: var(--text); margin-left: 24rpx; }
.menu-badge {
  background: rgba(232, 168, 56, 0.15);
  color: var(--accent1);
  font-size: 20rpx;
  padding: 2rpx 12rpx;
  border-radius: 20rpx;
  white-space: nowrap;
  flex-shrink: 0;
  margin-right: 12rpx;
}
.menu-arrow { color: var(--text-sub); font-size: 32rpx; flex-shrink: 0; }
.menu-badge.highlight {
  background: rgba(232, 168, 56, 0.2);
  color: var(--accent1);
  font-weight: 700;
}
