<view class="app-shell" data-theme="{{currentTheme}}">
  <scroll-view scroll-y class="scroll-content">

    <!-- 空状态 -->
    <view class="empty-state fade-in" wx:if="{{!hasData}}">
      <view class="empty-emoji">📋</view>
      <view class="empty-title">暂无测评记录</view>
      <view class="empty-desc">完成体质问卷后，系统将自动记录您的体质变化趋势</view>
      <button class="cta-btn" bindtap="goToQuiz">前往测评</button>
    </view>

    <!-- 有数据 -->
    <block wx:else>
      <!-- 趋势折线图 -->
      <view class="section-title">体质分数趋势</view>
      <view class="trend-chart-box" wx:if="{{isPageReady}}">
        <line-chart chartData="{{trendData}}"></line-chart>
      </view>

      <!-- 历史记录列表 -->
      <view class="section-title" style="margin-top:40rpx;">历史记录</view>
      <view class="history-list">
        <view class="history-card fade-in"
              wx:for="{{historyList}}" wx:key="date"
              bindtap="goReportDetail" data-date="{{item.date}}">
          <view class="history-left">
            <view class="history-type">{{item.majorType}}</view>
            <view class="history-date">{{item.date}}</view>
          </view>
          <view class="history-score">
            <text class="history-score-num">{{item.score}}</text>
            <text class="history-score-unit">分</text>
          </view>
        </view>
      </view>
    </block>

  </scroll-view>
</view>
