.app-shell { height: auto; display: block; }
.scroll-content {
  min-height: 100vh;
  padding-bottom: 200rpx;
  background: var(--bg);
}

.hero {
  margin: 24rpx;
  border-radius: var(--radius);
  background: var(--card);
  border: 2rpx solid var(--border);
  padding: 40rpx 36rpx 32rpx;
}
.hero-badge {
  display: inline-block;
  background: var(--accent1);
  color: #0f0f18;
  font-size: 20rpx;
  font-weight: 700;
  padding: 4rpx 20rpx;
  border-radius: 40rpx;
  margin-bottom: 20rpx;
}
.hero-title { font-size: 44rpx; font-weight: 800; line-height: 1.3; }
.highlight { color: var(--accent1); }
.hero-subtitle { font-size: 24rpx; color: var(--text-sub); margin-top: 12rpx; }

.tasks-section { padding: 0 24rpx; }

.section-label {
  font-size: 22rpx;
  color: var(--text-sub);
  padding: 0 8rpx 16rpx;
}

.task-card {
  background: var(--card);
  border: 2rpx solid var(--border);
  border-radius: var(--radius);
  margin-bottom: 16rpx;
  padding: 28rpx 24rpx;
  transition: all 0.2s;
}
.task-card.done {
  opacity: 0.55;
  border-color: var(--green);
}
.task-card-body {
  display: flex;
  align-items: center;
  gap: 20rpx;
}
.task-icon {
  font-size: 40rpx;
  flex-shrink: 0;
}
.task-info {
  flex: 1;
  min-width: 0;
}
.task-name {
  font-size: 28rpx;
  font-weight: 600;
  line-height: 1.3;
}
.task-meta {
  font-size: 20rpx;
  color: var(--text-sub);
  margin-top: 6rpx;
}
.task-card-right {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 10rpx;
  flex-shrink: 0;
}
.task-reward {
  font-size: 24rpx;
  font-weight: 700;
  color: var(--accent1);
}
.task-action {
  font-size: 22rpx;
  padding: 6rpx 20rpx;
  border-radius: 40rpx;
  background: var(--accent1);
  color: #0f0f18;
  font-weight: 600;
}
.task-action.completed {
  background: var(--green);
  color: #fff;
}

.empty-state {
  text-align: center;
  padding: 80rpx 0;
}
.empty-icon { font-size: 72rpx; margin-bottom: 16rpx; }
.empty-text { font-size: 26rpx; color: var(--text-sub); }

.tip-card {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin: 32rpx 24rpx;
  padding: 24rpx;
  background: rgba(232,168,56,0.08);
  border: 2rpx solid rgba(232,168,56,0.2);
  border-radius: var(--radius);
}
.tip-icon { font-size: 36rpx; flex-shrink: 0; }
.tip-text { font-size: 24rpx; color: var(--text-sub); line-height: 1.5; }
