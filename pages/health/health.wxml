<view class="app-shell" data-theme="{{currentTheme}}">
  <scroll-view scroll-y class="scroll-content">
    <view class="hero fade-in">
      <view class="hero-badge">⚡ 华佗故里 · 亳州</view>
      <view class="hero-title">AI <text class="highlight">体质养生</text><br/>管家</view>
      <view class="hero-subtitle">华佗故里 · 亳州道地药材 · 九种体质精准调理</view>
      <view class="hero-stats">
        <view class="stat-item"><view class="stat-num">9</view><view class="stat-label">体质类型</view></view>
        <view class="stat-item"><view class="stat-num">20+</view><view class="stat-label">道地药材</view></view>
        <view class="stat-item"><view class="stat-num">5</view><view class="stat-label">闯关秘境</view></view>
        <view class="stat-item"><view class="stat-num">7</view><view class="stat-label">方案模块</view></view>
      </view>
    </view>

    <view class="rank-bar fade-in">
      <view class="rank-header">
        <view class="rank-title">⚔️ 我的养生战力</view>
        <view class="rank-level" style="{{rankBadgeStyle}}">{{rankInfo.rankName || '青铜行者'}}</view>
      </view>
      <view class="xp-bar-bg">
        <view class="xp-bar-fill" style="width:{{xpPercent}}%"></view>
      </view>
      <view class="xp-text">{{xpText || '加载中…'}}</view>
      <view class="rank-stages">
        <view class="stage {{item.status}} rank-{{item.key}}" wx:for="{{stageList}}" wx:key="level">
          <view class="stage-dot"></view>
          <text>{{item.short}}</text>
        </view>
      </view>
    </view>

    <view class="section-header">
      <view class="section-title">今日任务</view>
      <view class="section-more" bindtap="viewAllTasks">查看全部 ›</view>
    </view>
    <view class="blindbox-container fade-in">
      <view class="blindbox-tasks">
        <view class="task-item {{todayClocks[item.type] ? 'done' : ''}}"
              wx:for="{{dailyTasks}}" wx:key="id"
              bindtap="handleTaskTap" data-id="{{item.id}}" data-type="{{item.type}}" data-label="{{item.text}}" data-action="{{item.action}}" data-url="{{item.url}}">
          <view class="task-check {{item.action === 'navigate' ? 'nav' : ''}} {{todayClocks[item.type] ? 'done' : ''}}">{{todayClocks[item.type] ? '✓' : (item.action === 'navigate' ? '▶' : '')}}</view>
          <view class="task-text">{{item.text}}</view>
          <view class="task-reward">{{item.reward}}</view>
        </view>
      </view>
      <button class="open-box-btn" bindtap="handleOpenBox">🎁 完成任务·开盲盒</button>
    </view>

    <view class="section-header">
      <view class="section-title">我的养生报告</view>
      <view class="section-more" bindtap="loadReport">🔄 刷新</view>
    </view>
    <view class="report-card fade-in" wx:if="{{report}}">
      <view class="report-physical">
        <view class="physical-emoji">{{report.emoji || '💧'}}</view>
        <view>
          <view class="physical-name">{{report.name}}</view>
          <view class="physical-sub">综合体质测评 · 转化分 {{report.score}} · {{report.date}}</view>
        </view>
      </view>
      <view class="report-modules">
        <view class="report-module">
          <view class="module-title">🍵 茶饮方案</view>
          <view class="module-content">{{rec.tea}}<view class="module-tip">{{rec.teaTip}}</view></view>
        </view>
        <view class="report-module">
          <view class="module-title">🏃 运动方案</view>
          <view class="module-content">{{rec.exercise}}<view class="module-tip">{{rec.exerciseTip}}</view></view>
        </view>
        <view class="report-module">
          <view class="module-title">🥗 饮食建议</view>
          <view class="module-content">{{rec.diet}}<view class="module-tip">{{rec.dietTip}}</view></view>
        </view>
        <view class="report-module">
          <view class="module-title">🌙 作息调整</view>
          <view class="module-content">{{rec.routine}}<view class="module-tip">{{rec.routineTip}}</view></view>
        </view>
      </view>
    </view>

    <view class="report-card report-empty fade-in" wx:else>
      <view class="report-physical">
        <view class="physical-emoji">📋</view>
        <view>
          <view class="physical-name">暂无测评报告</view>
          <view class="physical-sub">完成体质测评后自动生成四大调理方案</view>
        </view>
      </view>
      <button class="open-box-btn" bindtap="goToQuiz" style="margin-top:24rpx">前往测评</button>
    </view>
    <view style="height:160rpx;"></view>
  </scroll-view>
</view>
