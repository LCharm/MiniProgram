.scroll-content {
  height: 100vh;
  padding-bottom: 200rpx;
  background: var(--bg, #0f0f18);
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 48rpx;
  text-align: center;
}
.empty-emoji { font-size: 100rpx; margin-bottom: 24rpx; }
.empty-title { font-size: 36rpx; font-weight: 800; margin-bottom: 16rpx; }
.empty-desc { font-size: 26rpx; color: var(--text-sub); margin-bottom: 48rpx; line-height: 1.6; }

.hero {
  margin: 24rpx;
  border-radius: var(--radius);
  background: var(--card);
  border: 2rpx solid var(--border);
  padding: 40rpx 36rpx 32rpx;
}
.hero-badge {
  display: inline-block;
  background: var(--accent1);
  color: #0f0f18;
  font-size: 20rpx;
  font-weight: 700;
  padding: 4rpx 20rpx;
  border-radius: 40rpx;
  margin-bottom: 24rpx;
}
.hero-main { display: flex; align-items: center; gap: 28rpx; }
.major-emoji { font-size: 96rpx; }
.major-name { font-size: 48rpx; font-weight: 900; color: var(--accent2); }
.major-score { font-size: 24rpx; color: var(--text-sub); margin-top: 8rpx; }
.major-date { font-size: 22rpx; color: var(--text-sub); margin-top: 4rpx; }
.highlight { color: var(--accent1); font-weight: 800; }

.tip-card {
  margin: 0 24rpx 20rpx;
  border-radius: var(--radius);
  background: var(--card);
  border: 2rpx solid var(--border);
  padding: 28rpx 32rpx;
}
.tip-text { font-size: 26rpx; line-height: 1.8; color: var(--text); }

.details-card {
  margin: 0 24rpx 20rpx;
  border-radius: var(--radius);
  background: var(--card);
  border: 2rpx solid var(--border);
  padding: 8rpx 0;
}
.detail-row {
  display: flex;
  align-items: center;
  padding: 20rpx 32rpx;
  gap: 16rpx;
  border-bottom: 1rpx solid var(--border);
}
.detail-row:last-child { border-bottom: none; }
.detail-row.major { background: rgba(232, 168, 56, 0.08); }
.detail-emoji { font-size: 36rpx; }
.detail-name { flex: 1; font-size: 26rpx; font-weight: 600; }
.detail-score { font-size: 24rpx; color: var(--text-sub); margin-right: 8rpx; }
.detail-judgment {
  font-size: 20rpx;
  padding: 4rpx 16rpx;
  border-radius: 16rpx;
  font-weight: 600;
}
.judgment-yes { background: rgba(67, 160, 71, 0.2); color: #43A047; }
.judgment-maybe { background: rgba(255, 183, 77, 0.2); color: #FFB74D; }
.judgment-no { background: rgba(255, 255, 255, 0.06); color: var(--text-sub); }

.report-card {
  margin: 0 24rpx 20rpx;
  border-radius: var(--radius);
  background: var(--card);
  border: 2rpx solid var(--border);
  padding: 32rpx;
}
.report-modules { display: grid; grid-template-columns: 1fr 1fr; gap: 16rpx; }
.report-module { background: var(--surface); border-radius: 20rpx; padding: 20rpx; font-size: 20rpx; }
.module-title { font-weight: 700; margin-bottom: 8rpx; color: var(--accent2); }
.module-content { color: var(--text); line-height: 1.7; font-weight: 600; }
.module-tip { color: var(--text-sub); font-weight: 400; margin-top: 4rpx; }

.action-btns { margin: 40rpx 24rpx 0; display: flex; flex-direction: column; gap: 20rpx; }
.cta-btn {
  background: var(--accent1);
  color: #0f0f18;
  border-radius: 24rpx;
  font-size: 28rpx;
  font-weight: 800;
  height: 80rpx;
  line-height: 1;
  display: flex;
  align-items: center;
  justify-content: center;
}
.secondary-btn {
  background: transparent;
  color: var(--accent2);
  border: 2rpx solid var(--accent2);
  border-radius: 24rpx;
  font-size: 28rpx;
  font-weight: 700;
  height: 80rpx;
  line-height: 1;
  display: flex;
  align-items: center;
  justify-content: center;
}

.section-header { display: flex; align-items: center; justify-content: space-between; padding: 28rpx 24rpx 16rpx; }
.section-title { font-size: 30rpx; font-weight: 700; display: flex; align-items: center; gap: 12rpx; }
.section-title::before { content: ''; display: block; width: 6rpx; height: 32rpx; background: var(--accent1); border-radius: 4rpx; }
