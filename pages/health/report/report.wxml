<view class="app-shell" data-theme="{{currentTheme}}">
  <scroll-view scroll-y class="scroll-content">

    <!-- 空状态 -->
    <view class="empty-state fade-in" wx:if="{{!report}}">
      <view class="empty-emoji">📋</view>
      <view class="empty-title">暂无测评报告</view>
      <view class="empty-desc">完成体质问卷后，系统将自动生成您的专属养生报告</view>
      <button class="cta-btn" bindtap="goToQuiz">前往测评</button>
    </view>

    <!-- 报告内容 -->
    <block wx:else>
      <view class="hero fade-in">
        <view class="hero-badge">AI 体质判定报告</view>
        <view class="hero-main">
          <view class="major-emoji">{{report.emoji || '💧'}}</view>
          <view class="major-info">
            <view class="major-name">{{report.name}}</view>
            <view class="major-score">转化分 <text class="highlight">{{report.score}}</text></view>
            <view class="major-date">测评日期：{{report.date}}</view>
          </view>
        </view>
      </view>

      <!-- 体质分析 -->
      <view class="section-header">
        <view class="section-title">体质分析</view>
      </view>
      <view class="tip-card fade-in">
        <view class="tip-text">{{tip}}</view>
      </view>

      <!-- 九种体质分数 -->
      <view class="section-header">
        <view class="section-title">九种体质转化分</view>
      </view>
      <view class="details-card fade-in">
        <view class="detail-row {{item.isMajor ? 'major' : ''}}" wx:for="{{details}}" wx:key="id">
          <view class="detail-emoji">{{item.emoji}}</view>
          <view class="detail-name">{{item.name}}</view>
          <view class="detail-score">{{item.score}}分</view>
          <view class="detail-judgment judgment-{{item.judgment === '是' ? 'yes' : item.judgment === '倾向是' ? 'maybe' : 'no'}}">{{item.judgment}}</view>
        </view>
      </view>

      <!-- 四大养生方案 -->
      <view class="section-header">
        <view class="section-title">专属养生方案</view>
      </view>
      <view class="report-card fade-in" wx:if="{{rec}}">
        <view class="report-modules">
          <view class="report-module">
            <view class="module-title">🍵 茶饮方案</view>
            <view class="module-content">{{rec.tea}}<view class="module-tip">{{rec.teaTip}}</view></view>
          </view>
          <view class="report-module">
            <view class="module-title">🏃 运动方案</view>
            <view class="module-content">{{rec.exercise}}<view class="module-tip">{{rec.exerciseTip}}</view></view>
          </view>
          <view class="report-module">
            <view class="module-title">🥗 饮食建议</view>
            <view class="module-content">{{rec.diet}}<view class="module-tip">{{rec.dietTip}}</view></view>
          </view>
          <view class="report-module">
            <view class="module-title">🌙 作息调整</view>
            <view class="module-content">{{rec.routine}}<view class="module-tip">{{rec.routineTip}}</view></view>
          </view>
        </view>
      </view>

      <view class="action-btns">
        <button class="cta-btn" bindtap="goBack">返回首页</button>
        <button class="secondary-btn" bindtap="goToQuiz">重新测评</button>
      </view>

      <view style="height:80rpx;"></view>
    </block>

  </scroll-view>
</view>
