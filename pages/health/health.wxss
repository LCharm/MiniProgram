.scroll-content {
  height: 100vh;
  padding-bottom: 200rpx; /* 避开底部 tabBar */
  background: var(--bg, #0f0f18);
}

.hero {
  margin: 24rpx;
  border-radius: var(--radius);
  background: var(--card);
  border: 2rpx solid var(--border);
  padding: 40rpx 36rpx 32rpx;
  position: relative;
  overflow: hidden;
}
.hero-badge {
  display: inline-block;
  background: var(--accent1);
  color: #0f0f18;
  font-size: 20rpx;
  font-weight: 700;
  padding: 4rpx 20rpx;
  border-radius: 40rpx;
  margin-bottom: 20rpx;
}
.hero-title { font-size: 44rpx; font-weight: 800; line-height: 1.3; }
.highlight { color: var(--accent1); }
.hero-subtitle { font-size: 24rpx; color: var(--text-sub); margin-top: 12rpx; }
.hero-stats {
  display: flex;
  gap: 32rpx;
  margin-top: 28rpx;
  padding-top: 28rpx;
  border-top: 2rpx solid var(--border);
}
.stat-item { text-align: center; }
.stat-num { font-size: 36rpx; font-weight: 800; color: var(--accent1); }
.stat-label { font-size: 20rpx; color: var(--text-sub); }

.rank-bar {
  background: var(--card);
  margin: 0 24rpx 20rpx;
  border-radius: var(--radius);
  padding: 28rpx;
  border: 2rpx solid var(--border);
}
.rank-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 20rpx; }
.rank-title { font-size: 26rpx; font-weight: 700; }
.rank-level {
  font-size: 22rpx;
  padding: 4rpx 20rpx;
  border-radius: 40rpx;
  font-weight: 700;
}
.xp-bar-bg {
  height: 16rpx;
  background: var(--border);
  border-radius: 20rpx;
  overflow: hidden;
  margin-bottom: 12rpx;
}
.xp-bar-fill {
  height: 100%;
  border-radius: 20rpx;
  background: linear-gradient(90deg, var(--accent2), var(--accent1));
}
.xp-text { font-size: 20rpx; color: var(--text-sub); text-align: right; }
.rank-stages { display: flex; justify-content: space-between; margin-top: 20rpx; }
.stage { display: flex; flex-direction: column; align-items: center; gap: 6rpx; font-size: 18rpx; color: var(--text-sub); }
.stage-dot {
  width: 16rpx; height: 16rpx; border-radius: 50%;
  background: var(--border);
  border: 2rpx solid transparent;
}

/* ===== 段位配色 — 中式器物低饱和暖调 ===== */

/* 青铜行者 — 粗陶药钵 */
.stage.rank-bronze { color: #C49F76; }
.stage.rank-bronze.done .stage-dot,
.stage.rank-bronze.current .stage-dot { background: #634A35; border-color: #C49F76; box-shadow: 0 0 8px rgba(211,175,128,0.5); }
.stage.rank-bronze.locked .stage-dot { background: transparent; border-color: #634A35; }

/* 白银药师 — 锡制药罐 */
.stage.rank-silver { color: #F2F3F5; }
.stage.rank-silver.done .stage-dot,
.stage.rank-silver.current .stage-dot { background: #C8C9CB; border-color: #E0E2E5; box-shadow: 0 0 8px rgba(224,226,229,0.5); }
.stage.rank-silver.locked .stage-dot { background: transparent; border-color: #B0B3B8; }

/* 黄金医士 — 鎏金医书 */
.stage.rank-gold { color: #FFDD8A; }
.stage.rank-gold.done .stage-dot,
.stage.rank-gold.current .stage-dot { background: #C99F30; border-color: #FFE8A0; box-shadow: 0 0 8px rgba(255,241,182,0.5); }
.stage.rank-gold.locked .stage-dot { background: transparent; border-color: #C99F30; }

/* 翡翠圣医 — 青玉本草 */
.stage.rank-emerald { color: #B6E9E1; }
.stage.rank-emerald.done .stage-dot,
.stage.rank-emerald.current .stage-dot { background: #348C7F; border-color: #63E1D0; box-shadow: 0 0 8px rgba(99,225,208,0.4); }
.stage.rank-emerald.locked .stage-dot { background: transparent; border-color: #348C7F; }

/* 华佗王者 — 朱砂鎏金（双层光晕） */
.stage.rank-king { color: #FFD66F; }
.stage.rank-king.done .stage-dot,
.stage.rank-king.current .stage-dot {
  background: #8C2C26;
  border-color: #FF6969;
  box-shadow: 0 0 10px rgba(255,105,105,0.4), 0 0 14px rgba(255,214,111,0.3);
}
.stage.rank-king.locked .stage-dot { background: transparent; border-color: #8C2C26; }

.section-header { display: flex; align-items: center; justify-content: space-between; padding: 28rpx 24rpx 16rpx; }
.section-title { font-size: 30rpx; font-weight: 700; display: flex; align-items: center; gap: 12rpx; }
.section-title::before { content: ''; display: block; width: 6rpx; height: 32rpx; background: var(--accent1); border-radius: 4rpx; }
.section-more { font-size: 22rpx; color: var(--accent2); }

.blindbox-container {
  background: var(--card);
  margin: 0 24rpx 20rpx;
  border-radius: var(--radius);
  padding: 32rpx;
  border: 2rpx solid var(--border);
}
.task-item {
  display: flex;
  align-items: center;
  background: var(--surface);
  border-radius: 20rpx;
  padding: 20rpx 24rpx;
  margin-bottom: 16rpx;
  gap: 20rpx;
  font-size: 24rpx;
}
.task-check {
  width: 40rpx; height: 40rpx;
  border-radius: 50%;
  border: 4rpx solid var(--border);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 20rpx;
  transition: all 0.25s ease;
}
.task-check.nav { border-color: var(--accent2); color: var(--accent2); font-size: 16rpx; }
.task-check.done {
  background: var(--green);
  border-color: var(--green);
  animation: checkPop 0.35s ease;
}
@keyframes checkPop {
  0% { transform: scale(1); }
  40% { transform: scale(1.35); }
  100% { transform: scale(1); }
}
.task-text { flex: 1; }
.task-reward { font-size: 20rpx; color: var(--accent1); font-weight: 600; }
.open-box-btn {
  background: var(--accent1);
  color: #0f0f18;
  border-radius: 24rpx;
  font-size: 28rpx;
  font-weight: 800;
  margin-top: 10rpx;
  height: 80rpx;
  line-height: 1;
  padding: 0;
  display: flex;
  align-items: center;
  justify-content: center;
}

.report-card {
  background: var(--card);
  margin: 0 24rpx 20rpx;
  border-radius: var(--radius);
  padding: 32rpx;
  border: 2rpx solid var(--border);
}
.report-physical {
  display: flex;
  align-items: center;
  gap: 24rpx;
  margin-bottom: 28rpx;
  padding-bottom: 24rpx;
  border-bottom: 2rpx solid var(--border);
}
.physical-emoji { font-size: 80rpx; }
.physical-name { font-size: 40rpx; font-weight: 900; color: var(--accent2); }
.physical-sub { font-size: 22rpx; color: var(--text-sub); margin-top: 4rpx; }
.report-modules { display: grid; grid-template-columns: 1fr 1fr; gap: 16rpx; }
.report-module { background: var(--surface); border-radius: 20rpx; padding: 20rpx; font-size: 20rpx; }
.module-title { font-weight: 700; margin-bottom: 8rpx; color: var(--accent2); }
.module-content { color: var(--text); line-height: 1.7; font-weight: 600; }
.module-tip { color: var(--text-sub); font-weight: 400; margin-top: 4rpx; }

/* 任务完成态 */
.task-item { transition: all 0.2s; }
.task-item.done { opacity: 0.5; }
.task-item.done .task-text { text-decoration: line-through; }

.report-empty { border-color: var(--border); background: var(--card); }
.report-empty .physical-name { color: var(--text-sub); font-size: 32rpx; }
.report-empty .open-box-btn { margin: 0; width: 100% !important; }
