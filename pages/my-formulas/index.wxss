.app-shell { height: auto; display: block; }
.page-container {
  background: var(--bg, #0f0f18);
  min-height: 100vh;
}

/* ===== Tab 头部 ===== */
.tab-header {
  display: flex;
  background: var(--card);
  border-bottom: 2rpx solid var(--border);
  position: sticky;
  top: 0;
  z-index: 10;
}

.tab-item {
  flex: 1;
  text-align: center;
  padding: 24rpx 0;
  font-size: 28rpx;
  color: var(--text-sub);
  position: relative;
}

.tab-item.active {
  color: var(--accent1);
  font-weight: bold;
}

.tab-item.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 30%;
  width: 40%;
  height: 6rpx;
  background: var(--accent1);
  border-radius: 4rpx;
}

/* ===== 列表容器 ===== */
.list-container {
  padding: 24rpx;
}

/* ===== 卡片通用 ===== */
.formula-card {
  background: var(--card);
  border: 2rpx solid var(--border);
  border-radius: var(--radius);
  padding: 28rpx;
  margin-bottom: 20rpx;
}

.card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.card-header .title {
  font-size: 32rpx;
  font-weight: 800;
  color: var(--text);
  flex: 1;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* ===== 状态标签（仅我提交的） ===== */
.status-tag {
  font-size: 22rpx;
  font-weight: 600;
  padding: 6rpx 18rpx;
  border-radius: 20rpx;
  flex-shrink: 0;
  margin-left: 16rpx;
}

.status-0 {
  background: rgba(232, 168, 56, 0.12);
  color: var(--accent1);
}

.status-1 {
  background: rgba(107, 203, 119, 0.12);
  color: var(--green);
}

.status-2 {
  background: rgba(255, 107, 107, 0.12);
  color: #ff6b6b;
}

/* ===== 收藏标签 ===== */
.collected-tags {
  display: flex;
  gap: 8rpx;
  flex-shrink: 0;
  margin-left: 12rpx;
}

.ctag {
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  background: rgba(78, 205, 196, 0.12);
  color: var(--accent2);
  border-radius: 12rpx;
}

/* ===== 卡片内容 ===== */
.card-body {
  padding-top: 16rpx;
  border-top: 1rpx solid var(--border);
}

.info-row {
  display: flex;
  margin-bottom: 8rpx;
  line-height: 1.6;
}

.info-row .label {
  font-size: 24rpx;
  color: var(--accent1);
  font-weight: 600;
  flex-shrink: 0;
  width: 90rpx;
}

.info-row .value {
  font-size: 24rpx;
  color: var(--text-sub);
  flex: 1;
}

.time-row {
  margin-top: 12rpx;
  justify-content: flex-end;
}

.time-row .time {
  font-size: 22rpx;
  color: var(--text-sub);
  opacity: 0.6;
}

/* ===== 驳回原因 ===== */
.reject-reason {
  margin-top: 20rpx;
  padding: 16rpx 20rpx;
  background: rgba(255, 107, 107, 0.08);
  border-left: 4rpx solid #ff6b6b;
  border-radius: 6rpx;
  font-size: 24rpx;
  color: #ff6b6b;
  line-height: 1.5;
}

/* ===== 空状态 ===== */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 160rpx 40rpx;
  gap: 16rpx;
}

.empty-icon {
  font-size: 80rpx;
  opacity: 0.5;
}

.empty-text {
  font-size: 28rpx;
  color: var(--text-sub);
  font-weight: 600;
}
