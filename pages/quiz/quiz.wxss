.scroll-content {
  flex: 1;
  height: 0;
  background: var(--bg);
}

/* 头部 Banner */
.hero {
  border-radius: var(--radius);
  background: var(--card);
  padding: 40rpx 36rpx 32rpx;
  position: relative;
  overflow: hidden;
}
.hero::before {
  content: '';
  position: absolute;
  top: -60rpx; right: -60rpx;
  width: 240rpx; height: 240rpx;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(232,168,56,0.3), transparent);
}
.hero-badge {
  display: inline-block;
  background: var(--accent1);
  color: #0f0f18;
  font-size: 20rpx;
  font-weight: 700;
  padding: 4rpx 20rpx;
  border-radius: 40rpx;
  margin-bottom: 20rpx;
}
.hero-title { font-size: 44rpx; font-weight: 800; line-height: 1.3; }
.highlight { color: var(--accent1); }
.hero-subtitle { font-size: 22rpx; color: var(--text-sub); margin-top: 12rpx; }

/* 标题样式 */
.section-header { display: flex; align-items: center; justify-content: space-between; padding: 28rpx 24rpx 16rpx; }
.section-title {
  font-size: 32rpx; font-weight: 800;
  color: var(--text);
  margin-bottom: 32rpx;
  position: relative;
  padding-left: 24rpx;
  display: flex;
  align-items: center;
}
.section-title::before {
  content: '';
  position: absolute;
  left: 0;
  top: 50%;
  transform: translateY(-50%);
  width: 8rpx;
  height: 30rpx;
  background: #e8a838;
  border-radius: 4rpx;
}

/* 九宫格 */
.physical-types {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 20rpx;
  padding: 0 24rpx 20rpx;
}
.physical-chip {
  background: var(--card);
  border: 2rpx solid var(--border);
  border-radius: 20rpx;
  padding: 24rpx 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  transition: all 0.2s;
}
.physical-chip.active { border-color: var(--accent1); background: rgba(232, 168, 56, 0.1); }
.physical-chip-img { width: 120rpx; height: 120rpx; display: block; border-radius: 50%; margin-bottom: 0; }
.physical-chip .name { font-size: 26rpx; font-weight: bold; color: var(--text); }

/* 问卷答题区 */
.quiz-card-wrapper {
  background: var(--card);
  margin: 0 24rpx 20rpx;
  border-radius: var(--radius);
  padding: 40rpx 32rpx;
  border: 2rpx solid var(--border);
}
.quiz-progress { display: flex; align-items: center; gap: 16rpx; margin-bottom: 32rpx; }
.quiz-num { font-size: 26rpx; font-weight: 700; color: var(--text); }
.quiz-bar-bg { flex: 1; height: 8rpx; background: var(--border); border-radius: 8rpx; overflow: hidden; }
.quiz-bar-fill { height: 100%; background: var(--accent1); border-radius: 8rpx; transition: width 0.3s ease; }

.question-type {
  display: inline-block;
  font-size: 20rpx;
  color: var(--accent2);
  background: rgba(78, 205, 196, 0.1);
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
  margin-bottom: 20rpx;
}
.quiz-q { font-size: 32rpx; font-weight: 800; line-height: 1.6; margin-bottom: 40rpx; }

.quiz-options { display: flex; flex-direction: column; gap: 20rpx; }
.quiz-opt {
  padding: 24rpx 28rpx;
  background: var(--surface);
  border: 2rpx solid var(--border);
  border-radius: 20rpx;
  font-size: 26rpx;
  transition: all 0.2s;
}
.quiz-opt.selected { background: rgba(232, 168, 56, 0.2); border-color: var(--accent1); color: var(--accent1); font-weight: bold; }

/* 问卷操作按钮 */
.action-footer { margin-top: 40rpx; display: flex; }
.nav-btn {
  margin: 0; height: 80rpx; line-height: 1;
  border-radius: 40rpx; font-size: 28rpx; font-weight: bold;
  padding: 0;
  display: flex;
  align-items: center;
  justify-content: center;
}
.prev-btn { flex: 1; background: var(--surface); color: var(--text); border: 2rpx solid var(--border); }
.submit-btn { background: var(--accent1); color: #0f0f18; width: 100% !important; }

/* 问卷前置状态 */
.step-gender, .step-intermission { text-align: center; }
.gender-title, .intermission-title { font-size: 32rpx; font-weight: 800; margin-bottom: 40rpx; }
.intermission-desc { font-size: 26rpx; color: var(--text-sub); line-height: 1.6; margin-bottom: 60rpx; text-align: left; }
.gender-options {
  display: flex; justify-content: space-evenly;
  margin-top: 40rpx;
}
.gender-card {
  display: flex; flex-direction: column; align-items: center;
  opacity: 0.6;
  transition: all 0.3s ease;
}
.gender-card.active { opacity: 1; transform: scale(1.05); }
.avatar-wrapper {
  width: 220rpx; height: 220rpx;
  background: var(--card);
  border-radius: 50%;
  display: flex; justify-content: center; align-items: center;
  border: 4rpx solid transparent;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.04);
  transition: all 0.3s ease;
}
.gender-card.active .avatar-wrapper {
  border-color: #e8a838;
  background: rgba(232, 168, 56, 0.1);
  box-shadow: 0 0 30rpx rgba(232, 168, 56, 0.2);
}
.gender-avatar { width: 80%; height: 80%; display: block; }
.gender-label { font-size: 32rpx; font-weight: bold; color: var(--text); letter-spacing: 8rpx; }

/* 开始测评按钮 */
.action-section { margin-top: 70rpx; margin-bottom: 40rpx; display: flex; justify-content: center; }
.start-btn {
  width: 80%; height: 96rpx; border-radius: 48rpx;
  background: var(--surface);
  color: var(--text-sub);
  font-size: 32rpx; font-weight: bold;
  display: flex; align-items: center; justify-content: center;
  transition: all 0.3s ease;
  border: 2rpx solid var(--border);
}
.start-btn[disabled] {
  background: var(--surface) !important;
  color: var(--text-sub) !important;
}
.start-btn.ready {
  background: linear-gradient(135deg, #e8a838, #d49324);
  color: #fff;
  box-shadow: 0 12rpx 24rpx rgba(232, 168, 56, 0.25);
  transform: translateY(-4rpx);
}

/* 舌象空壳 */
.tongue-entry {
  background: var(--card);
  margin: 0 24rpx 20rpx;
  border-radius: var(--radius);
  padding: 32rpx;
  border: 2rpx solid var(--border);
  text-align: center;
  margin-top: 20rpx;
}
.tongue-icon { font-size: 56rpx; margin-bottom: 12rpx; }
.tongue-title { font-weight: 800; font-size: 28rpx; margin-bottom: 8rpx; }
.tongue-desc { font-size: 22rpx; color: var(--text-sub); }

/* ===== 测评结果 ===== */
.step-result { text-align: center; }

.result-header {
  padding-bottom: 32rpx;
  border-bottom: 2rpx solid var(--border);
  margin-bottom: 28rpx;
}
.result-emoji-img { width: 160rpx; height: 160rpx; margin: 0 auto 12rpx; display: block; border-radius: 50%; }
.result-type {
  font-size: 44rpx;
  font-weight: 900;
  color: var(--accent1);
  margin-bottom: 10rpx;
}
.result-score {
  font-size: 26rpx;
  color: var(--text-sub);
}
.result-date {
  font-size: 22rpx;
  color: var(--text-sub);
  opacity: 0.6;
  margin-top: 6rpx;
}

.result-tip {
  background: rgba(232, 168, 56, 0.08);
  border: 1rpx solid rgba(232, 168, 56, 0.15);
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
  text-align: left;
}

.result-tie-warn {
  background: rgba(255, 107, 107, 0.1);
  border: 1rpx solid rgba(255, 107, 107, 0.25);
  border-radius: 16rpx;
  padding: 20rpx 24rpx;
  margin-bottom: 28rpx;
  display: flex;
  align-items: flex-start;
  gap: 12rpx;
}
.tie-icon { font-size: 28rpx; flex-shrink: 0; margin-top: 2rpx; }
.tie-text { font-size: 22rpx; color: #ff8a8a; line-height: 1.6; }
.tip-title { font-size: 24rpx; font-weight: 700; color: var(--accent1); margin-bottom: 10rpx; }
.tip-text { font-size: 24rpx; color: var(--text); line-height: 1.7; }

.result-details { margin-bottom: 32rpx; }
.details-title {
  font-size: 24rpx;
  font-weight: 700;
  color: var(--text-sub);
  margin-bottom: 16rpx;
  text-align: left;
}
.details-list {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}
.detail-item {
  display: flex;
  align-items: center;
  gap: 14rpx;
  padding: 16rpx 20rpx;
  background: var(--surface);
  border-radius: 12rpx;
  border: 2rpx solid transparent;
}
.detail-item.highlight {
  background: rgba(232, 168, 56, 0.15);
  border-color: var(--accent1);
}
.detail-emoji { font-size: 32rpx; width: 48rpx; text-align: center; }
.detail-name { font-size: 24rpx; color: var(--text); flex: 1; text-align: left; }
.detail-score { font-size: 24rpx; font-weight: 700; color: var(--text); width: 70rpx; text-align: right; }
.detail-judgment {
  font-size: 20rpx;
  padding: 4rpx 14rpx;
  border-radius: 16rpx;
  font-weight: 600;
  width: 80rpx;
  text-align: center;
}
.judgment-yes { background: rgba(232, 168, 56, 0.15); color: var(--accent1); }
.judgment-maybe { background: rgba(78, 205, 196, 0.12); color: var(--accent2); }
.judgment-no { background: var(--surface); color: var(--text-sub); }

.result-actions { margin-top: 32rpx; }
.result-actions .nav-btn { width: 100% !important; }
.report-link-btn {
  background: linear-gradient(135deg, #43A047, #2E7D32) !important;
  color: #fff !important;
  animation: reportPulse 2s ease-in-out infinite;
}
@keyframes reportPulse {
  0%, 100% { box-shadow: 0 0 0 0 rgba(67, 160, 71, 0.4); }
  50% { box-shadow: 0 0 0 12rpx rgba(67, 160, 71, 0); }
}

/* ===== 神游古迹景点答题 ===== */
.lm-scroll-bg {
  background: #F4EFE6;
  position: relative;
}

/* 步骤指示器 */
.lm-stepper {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 0;
  padding: 36rpx 0 12rpx;
}
.lm-stepper-dot {
  width: 24rpx;
  height: 24rpx;
  border-radius: 50%;
  background: #D6C8B5;
  transition: all 0.4s;
}
.lm-stepper-dot.active {
  background: #5C3A21;
  box-shadow: 0 0 16rpx rgba(92,58,33,0.35);
}
.lm-stepper-line {
  width: 80rpx;
  height: 4rpx;
  background: #D6C8B5;
  transition: all 0.4s;
}
.lm-stepper-line.active {
  background: #5C3A21;
}
.lm-stepper-label {
  text-align: center;
  font-size: 24rpx;
  color: #8B7355;
  letter-spacing: 4rpx;
  margin-bottom: 24rpx;
}

/* 叠层卡片 */
.lm-card-stacked {
  position: relative;
  box-shadow: 0 8rpx 40rpx rgba(92,58,33,0.10), 0 2rpx 8rpx rgba(92,58,33,0.06);
}
.lm-card-stacked::after {
  content: '';
  position: absolute;
  left: 12rpx;
  right: 12rpx;
  bottom: -12rpx;
  height: 24rpx;
  background: rgba(255,255,255,0.7);
  border-radius: 0 0 var(--radius) var(--radius);
  z-index: -1;
  border: 2rpx solid var(--border);
  border-top: none;
}

/* 底部提示 */
.lm-hint {
  margin-top: 16rpx;
  padding: 16rpx 20rpx;
  background: rgba(92,58,33,0.04);
  border: 1rpx solid rgba(92,58,33,0.08);
  border-radius: 12rpx;
  text-align: center;
  font-size: 22rpx;
  color: #8B7355;
}

/* 水印 */
.lm-watermark {
  position: fixed;
  bottom: 120rpx;
  right: 40rpx;
  font-size: 120rpx;
  font-weight: 900;
  color: rgba(92,58,33,0.03);
  font-family: 'STKaiti', 'KaiTi', '楷体', serif;
  pointer-events: none;
  z-index: 0;
  letter-spacing: 20rpx;
}

.lm-quiz-card {
  background: var(--card);
  margin: 0 24rpx 20rpx;
  border-radius: var(--radius);
  padding: 32rpx 28rpx;
  border: 2rpx solid var(--border);
}

.lm-loading {
  text-align: center;
  padding: 80rpx 0;
  font-size: 28rpx;
  color: var(--text-sub);
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
}
.lm-loading-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background: var(--accent1);
  animation: lmDotPulse 1.2s ease-in-out infinite;
}
@keyframes lmDotPulse {
  0%, 100% { opacity: 0.3; transform: scale(0.8); }
  50% { opacity: 1; transform: scale(1.2); }
}

.lm-question {
  font-size: 30rpx;
  font-weight: 700;
  line-height: 1.7;
  margin-bottom: 32rpx;
  color: var(--text);
}

.lm-options {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  margin-bottom: 20rpx;
}

.lm-opt {
  display: flex;
  align-items: center;
  padding: 26rpx 28rpx;
  background: #fff;
  border: 2rpx solid var(--border);
  border-radius: 16rpx;
  font-size: 26rpx;
  color: var(--text);
  transition: all 0.2s;
  gap: 12rpx;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.04);
}
.lm-opt:active {
  background: rgba(184,115,51,0.06);
  border-color: var(--accent1);
}

.lm-opt-key {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  background: rgba(92,58,33,0.08);
  font-weight: 700;
  font-size: 22rpx;
  flex-shrink: 0;
  color: var(--sandalwood);
}

.lm-opt-icon {
  margin-left: auto;
  font-size: 28rpx;
  flex-shrink: 0;
}

.lm-correct {
  border-color: var(--green) !important;
  background: rgba(107, 203, 119, 0.08) !important;
}
.lm-correct .lm-opt-key {
  background: var(--green);
  color: #fff;
}

.lm-wrong {
  border-color: var(--accent3) !important;
  background: rgba(255, 107, 157, 0.08) !important;
}
.lm-wrong .lm-opt-key {
  background: var(--accent3);
  color: #fff;
}

.lm-explanation {
  background: rgba(184,115,51,0.06);
  border-radius: 12rpx;
  padding: 20rpx 24rpx;
  font-size: 22rpx;
  color: var(--text-sub);
  line-height: 1.6;
  display: flex;
  gap: 14rpx;
  align-items: flex-start;
}
.lm-explanation-dot {
  width: 14rpx;
  height: 14rpx;
  border-radius: 50%;
  flex-shrink: 0;
  margin-top: 6rpx;
}
.lm-exp-correct { background: var(--green); }
.lm-exp-wrong { background: var(--accent3); }

.lm-next-btn {
  width: 100%;
  height: 80rpx;
  margin-top: 24rpx;
  padding: 0;
  background: #5C3A21;
  color: #fff;
  border-radius: 12rpx;
  font-size: 28rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  letter-spacing: 2rpx;
  line-height: 80rpx;
  border: none;
}
.lm-next-btn::after {
  border: none;
}

/* 结算结果 */
.lm-result {
  padding: 60rpx 36rpx 40rpx;
  text-align: center;
}

/* CSS 印章 */
.lm-stamp {
  width: 240rpx;
  height: 240rpx;
  border-radius: 50%;
  border: 8rpx solid;
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 0 auto 28rpx;
  transform: rotate(-8deg);
  opacity: 0.88;
}
.lm-stamp text {
  font-size: 120rpx;
  font-weight: 900;
  font-family: 'STKaiti', 'KaiTi', '楷体', serif;
  line-height: 1;
}
.lm-stamp-pass {
  border-color: #b85440;
  box-shadow: 0 0 32rpx rgba(184,84,64,0.2);
}
.lm-stamp-pass text {
  color: #b85440;
}
.lm-stamp-fail {
  border-color: #999;
}
.lm-stamp-fail text {
  color: #999;
}

.lm-result-status {
  font-size: 40rpx;
  font-weight: 700;
  color: var(--sandalwood);
  margin-bottom: 10rpx;
  font-family: 'STKaiti', 'KaiTi', '楷体', serif;
  letter-spacing: 6rpx;
}
.lm-result-score {
  font-size: 26rpx;
  color: var(--text-sub);
  margin-bottom: 16rpx;
}
.lm-score-num {
  font-size: 40rpx;
  font-weight: 800;
  color: var(--text);
}

.lm-result-cost {
  font-size: 26rpx;
  color: var(--text-sub);
  margin-bottom: 32rpx;
}
.lm-cost-num {
  color: var(--accent1);
  font-weight: 700;
}

.lm-reward-card {
  background: var(--card);
  border-radius: var(--radius);
  padding: 28rpx 32rpx;
  margin: 0 24rpx 24rpx;
  border: 2rpx solid var(--border);
  text-align: center;
}
.lm-reward-glow {
  border-color: rgba(184,115,51,0.3);
  box-shadow: 0 0 48rpx rgba(184,115,51,0.15), 0 4rpx 20rpx rgba(92,58,33,0.08);
  background: linear-gradient(135deg, rgba(255,248,240,1) 0%, rgba(244,239,230,1) 100%);
}
.lm-reward-label {
  font-size: 24rpx;
  color: var(--text-sub);
  margin-bottom: 12rpx;
}
.lm-reward-item {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  padding: 12rpx 0;
}
.lm-reward-tier {
  font-size: 20rpx;
  font-weight: 800;
  padding: 2rpx 12rpx;
  border-radius: 8rpx;
}
.lm-reward-tier.SSR { background: rgba(255,107,157,0.2); color: #ff6b9d; }
.lm-reward-tier.SR { background: rgba(184,115,51,0.15); color: var(--accent1); }
.lm-reward-tier.R { background: rgba(78,205,196,0.2); color: var(--accent2); }
.lm-reward-tier.N { background: rgba(107,203,119,0.2); color: var(--green); }
.lm-reward-name {
  font-size: 30rpx;
  font-weight: 700;
  color: var(--text);
}

.lm-fail-encourage {
  margin: 0 24rpx 32rpx;
  padding: 32rpx;
  text-align: center;
  border: 2rpx dashed rgba(92,58,33,0.15);
  border-radius: var(--radius);
  background: rgba(92,58,33,0.03);
}
.lm-fail-text {
  font-size: 28rpx;
  color: #8B7355;
  font-family: 'STKaiti', 'KaiTi', '楷体', serif;
  letter-spacing: 4rpx;
}

.lm-retry-btn {
  width: 480rpx;
  height: 80rpx;
  padding: 0;
  background: #5C3A21;
  color: #fff;
  border-radius: 12rpx;
  font-size: 28rpx;
  font-weight: 600;
  margin: 0 auto;
  display: flex;
  align-items: center;
  justify-content: center;
  letter-spacing: 2rpx;
  line-height: 80rpx;
  border: none;
}
.lm-retry-btn::after {
  border: none;
}
