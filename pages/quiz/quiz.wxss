.scroll-content {
  height: 100vh;
  background: var(--bg, #0f0f18);
}

/* 头部 Banner */
.hero {
  border-radius: var(--radius);
  background: var(--card);
  padding: 40rpx 36rpx 32rpx;
  position: relative;
  overflow: hidden;
}
.hero::before {
  content: '';
  position: absolute;
  top: -60rpx; right: -60rpx;
  width: 240rpx; height: 240rpx;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(232,168,56,0.3), transparent);
}
.hero-badge {
  display: inline-block;
  background: var(--accent1);
  color: #0f0f18;
  font-size: 20rpx;
  font-weight: 700;
  padding: 4rpx 20rpx;
  border-radius: 40rpx;
  margin-bottom: 20rpx;
}
.hero-title { font-size: 44rpx; font-weight: 800; line-height: 1.3; }
.highlight { color: var(--accent1); }
.hero-subtitle { font-size: 22rpx; color: var(--text-sub); margin-top: 12rpx; }

/* 标题样式 */
.section-header { display: flex; align-items: center; justify-content: space-between; padding: 28rpx 24rpx 16rpx; }
.section-title { font-size: 30rpx; font-weight: 700; display: flex; align-items: center; gap: 12rpx; }
.section-title::before { content: ''; display: block; width: 6rpx; height: 32rpx; background: var(--accent1); border-radius: 4rpx; }

/* 九宫格 */
.physical-types {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 16rpx;
  padding: 0 24rpx 20rpx;
}
.physical-chip {
  background: var(--card);
  border: 2rpx solid var(--border);
  border-radius: 20rpx;
  padding: 24rpx 12rpx;
  text-align: center;
  transition: all 0.2s;
}
.physical-chip.active { border-color: var(--accent1); background: rgba(232, 168, 56, 0.1); }
.physical-chip .emoji { font-size: 44rpx; display: block; margin-bottom: 8rpx; }
.physical-chip .name { font-size: 24rpx; font-weight: bold; }

/* 问卷答题区 */
.quiz-card-wrapper {
  background: var(--card);
  margin: 0 24rpx 20rpx;
  border-radius: var(--radius);
  padding: 40rpx 32rpx;
  border: 2rpx solid var(--border);
}
.quiz-progress { display: flex; align-items: center; gap: 16rpx; margin-bottom: 32rpx; }
.quiz-num { font-size: 26rpx; font-weight: 700; color: var(--text); }
.quiz-bar-bg { flex: 1; height: 8rpx; background: var(--border); border-radius: 8rpx; overflow: hidden; }
.quiz-bar-fill { height: 100%; background: var(--accent1); border-radius: 8rpx; transition: width 0.3s ease; }

.question-type {
  display: inline-block;
  font-size: 20rpx;
  color: var(--accent2);
  background: rgba(78, 205, 196, 0.1);
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
  margin-bottom: 20rpx;
}
.quiz-q { font-size: 32rpx; font-weight: 800; line-height: 1.6; margin-bottom: 40rpx; }

.quiz-options { display: flex; flex-direction: column; gap: 20rpx; }
.quiz-opt {
  padding: 24rpx 28rpx;
  background: var(--surface);
  border: 2rpx solid var(--border);
  border-radius: 20rpx;
  font-size: 26rpx;
  transition: all 0.2s;
}
.quiz-opt.selected { background: rgba(232, 168, 56, 0.2); border-color: var(--accent1); color: var(--accent1); font-weight: bold; }

/* 问卷操作按钮 */
.action-footer { margin-top: 40rpx; display: flex; }
.nav-btn {
  margin: 0; height: 80rpx; line-height: 1;
  border-radius: 40rpx; font-size: 28rpx; font-weight: bold;
  padding: 0;
  display: flex;
  align-items: center;
  justify-content: center;
}
.prev-btn { flex: 1; background: var(--surface); color: var(--text); border: 2rpx solid var(--border); }
.submit-btn { background: var(--accent1); color: #0f0f18; width: 100% !important; }

/* 问卷前置状态 */
.step-gender, .step-intermission { text-align: center; }
.gender-title, .intermission-title { font-size: 32rpx; font-weight: 800; margin-bottom: 40rpx; }
.intermission-desc { font-size: 26rpx; color: var(--text-sub); line-height: 1.6; margin-bottom: 60rpx; text-align: left; }
.gender-options { display: flex; gap: 40rpx; justify-content: center; }
.gender-card { background: var(--surface); border: 2rpx solid var(--border); border-radius: var(--radius); width: 200rpx; height: 240rpx; display: flex; flex-direction: column; align-items: center; justify-content: center; font-size: 32rpx; font-weight: bold; }
.gender-icon { font-size: 80rpx; margin-bottom: 20rpx; }

/* 舌象空壳 */
.tongue-entry {
  background: var(--card);
  margin: 0 24rpx 20rpx;
  border-radius: var(--radius);
  padding: 32rpx;
  border: 2rpx solid var(--border);
  text-align: center;
  margin-top: 20rpx;
}
.tongue-icon { font-size: 56rpx; margin-bottom: 12rpx; }
.tongue-title { font-weight: 800; font-size: 28rpx; margin-bottom: 8rpx; }
.tongue-desc { font-size: 22rpx; color: var(--text-sub); }

/* ===== 测评结果 ===== */
.step-result { text-align: center; }

.result-header {
  padding-bottom: 32rpx;
  border-bottom: 2rpx solid var(--border);
  margin-bottom: 28rpx;
}
.result-emoji { font-size: 96rpx; margin-bottom: 12rpx; }
.result-type {
  font-size: 44rpx;
  font-weight: 900;
  color: var(--accent1);
  margin-bottom: 10rpx;
}
.result-score {
  font-size: 26rpx;
  color: var(--text-sub);
}
.result-date {
  font-size: 22rpx;
  color: var(--text-sub);
  opacity: 0.6;
  margin-top: 6rpx;
}

.result-tip {
  background: rgba(232, 168, 56, 0.08);
  border: 1rpx solid rgba(232, 168, 56, 0.15);
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
  text-align: left;
}

.result-tie-warn {
  background: rgba(255, 107, 107, 0.1);
  border: 1rpx solid rgba(255, 107, 107, 0.25);
  border-radius: 16rpx;
  padding: 20rpx 24rpx;
  margin-bottom: 28rpx;
  display: flex;
  align-items: flex-start;
  gap: 12rpx;
}
.tie-icon { font-size: 28rpx; flex-shrink: 0; margin-top: 2rpx; }
.tie-text { font-size: 22rpx; color: #ff8a8a; line-height: 1.6; }
.tip-title { font-size: 24rpx; font-weight: 700; color: var(--accent1); margin-bottom: 10rpx; }
.tip-text { font-size: 24rpx; color: var(--text); line-height: 1.7; }

.result-details { margin-bottom: 32rpx; }
.details-title {
  font-size: 24rpx;
  font-weight: 700;
  color: var(--text-sub);
  margin-bottom: 16rpx;
  text-align: left;
}
.details-list {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}
.detail-item {
  display: flex;
  align-items: center;
  gap: 14rpx;
  padding: 16rpx 20rpx;
  background: var(--surface);
  border-radius: 12rpx;
  border: 2rpx solid transparent;
}
.detail-item.highlight {
  background: rgba(232, 168, 56, 0.15);
  border-color: var(--accent1);
}
.detail-emoji { font-size: 32rpx; width: 48rpx; text-align: center; }
.detail-name { font-size: 24rpx; color: var(--text); flex: 1; text-align: left; }
.detail-score { font-size: 24rpx; font-weight: 700; color: var(--text); width: 70rpx; text-align: right; }
.detail-judgment {
  font-size: 20rpx;
  padding: 4rpx 14rpx;
  border-radius: 16rpx;
  font-weight: 600;
  width: 80rpx;
  text-align: center;
}
.judgment-yes { background: rgba(232, 168, 56, 0.15); color: var(--accent1); }
.judgment-maybe { background: rgba(78, 205, 196, 0.12); color: var(--accent2); }
.judgment-no { background: var(--surface); color: var(--text-sub); }

.result-actions { margin-top: 32rpx; }
.result-actions .nav-btn { width: 100% !important; }
