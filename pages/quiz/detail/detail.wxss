/* pages/quiz/detail/detail.wxss — 体质详情报告页 */
.app-shell { height: auto; display: block; padding: 24rpx 24rpx 0; padding-bottom: 180rpx; min-height: 100vh; background: var(--bg); box-sizing: border-box; }

/* ═══════════ 1. 头部 ═══════════ */
.d-header { text-align: center; padding: 48rpx 16rpx 40rpx; border-bottom: 2rpx solid var(--border); margin-bottom: 28rpx; }
.d-header-img { width: 160rpx; height: 160rpx; margin: 0 auto 12rpx; display: block; border-radius: 50%; }
.d-header-name { font-size: 48rpx; font-weight: 900; color: var(--text); letter-spacing: 8rpx; margin-bottom: 20rpx; }
.d-header-desc { font-size: 26rpx; color: var(--text-sub); line-height: 1.85; padding: 0 8rpx; }

/* ═══════════ 通用区块 ═══════════ */
.d-section { margin-bottom: 28rpx; }
.d-section-label { font-size: 22rpx; font-weight: 700; color: var(--accent1); letter-spacing: 4rpx; margin-bottom: 16rpx; text-transform: uppercase; }

/* ═══════════ 通用卡片 ═══════════ */
.d-card { background: var(--card); border: 2rpx solid var(--border); border-radius: 16rpx; padding: 24rpx; }

/* ═══════════ 2. 基础诊断 ═══════════ */
.d-diag-row { display: flex; align-items: flex-start; gap: 14rpx; }
.d-diag-badge { flex-shrink: 0; font-size: 20rpx; color: var(--accent1); background: rgba(232,168,56,.12); padding: 6rpx 18rpx; border-radius: 8rpx; line-height: 1.4; }
.d-diag-text { font-size: 24rpx; color: var(--text); line-height: 1.85; word-break: break-all; }

/* ═══════════ 3. 特征切片区 ═══════════ */
.d-chip { margin-bottom: 12rpx; }
.d-chip:last-child { margin-bottom: 0; }
.d-chip-icon { font-size: 28rpx; margin-bottom: 4rpx; }
.d-chip-title { font-size: 22rpx; font-weight: 700; color: var(--text); margin-bottom: 10rpx; }
.d-chip-body { font-size: 24rpx; color: var(--text-sub); line-height: 1.85; word-break: break-all; }

/* ═══════════ 4. 风险预警区 ═══════════ */
.d-card-warn { background: rgba(184,84,64,.06); border-color: rgba(184,84,64,.2); }
.d-risk-item { display: flex; gap: 14rpx; margin-bottom: 18rpx; }
.d-risk-item:last-child { margin-bottom: 0; }
.d-risk-dot { width: 10rpx; height: 10rpx; background: var(--accent3); border-radius: 50%; margin-top: 10rpx; flex-shrink: 0; }
.d-risk-dot-env { background: var(--accent4); }
.d-risk-title { font-size: 22rpx; font-weight: 700; color: var(--text); margin-bottom: 6rpx; }
.d-risk-text { font-size: 24rpx; color: var(--text-sub); line-height: 1.85; word-break: break-all; }

/* ═══════════ 5. 核心调理区 ═══════════ */
.d-care-card { margin-bottom: 14rpx; }
.d-care-card:last-child { margin-bottom: 0; }
.d-care-head { display: flex; align-items: center; gap: 10rpx; margin-bottom: 12rpx; }
.d-care-icon { font-size: 28rpx; }
.d-care-title { font-size: 24rpx; font-weight: 700; color: var(--text); }
.d-care-content { font-size: 24rpx; color: var(--text-sub); line-height: 1.85; word-break: break-all; }

/* ═══════════ 底部安全区占位 ═══════════ */
.d-bottom-safe { height: 40rpx; }

/* ═══════════ 6. 底部悬浮按钮 ═══════════ */
.d-fixed-footer {
  position: fixed; bottom: 0; left: 0; right: 0; z-index: 100;
  padding: 24rpx 32rpx calc(24rpx + env(safe-area-inset-bottom));
  background: var(--bg);
  box-shadow: 0 -4rpx 20rpx rgba(0,0,0,0.06);
}
.d-footer-btn {
  width: 100%; height: 88rpx; line-height: 88rpx;
  background: var(--accent1); color: #1a1412;
  border-radius: 44rpx; font-size: 28rpx; font-weight: 700;
  letter-spacing: 2rpx; border: none; padding: 0; text-align: center;
}
.d-footer-btn::after { border: none; }
