<view class="app-shell" data-theme="{{currentTheme}}">

  <!-- ═══════════ 神游古迹：景点答题 ═══════════ -->
  <block wx:if="{{quizMode === 'landmark'}}">
    <scroll-view scroll-y class="scroll-content lm-scroll-bg">

      <!-- 加载中 -->
      <view class="lm-quiz-card" wx:if="{{landmarkLoading}}">
        <view class="lm-loading">
          <view class="lm-loading-dot"></view>
          <text>正在加载题目...</text>
        </view>
      </view>

      <!-- 答题中 -->
      <block wx:elif="{{!landmarkResult}}">
        <view class="lm-stepper fade-in">
          <view class="lm-stepper-dot {{landmarkIdx >= 0 ? 'active' : ''}}"></view>
          <view class="lm-stepper-line {{landmarkIdx >= 1 ? 'active' : ''}}"></view>
          <view class="lm-stepper-dot {{landmarkIdx >= 1 ? 'active' : ''}}"></view>
          <view class="lm-stepper-line {{landmarkIdx >= 2 ? 'active' : ''}}"></view>
          <view class="lm-stepper-dot {{landmarkIdx >= 2 ? 'active' : ''}}"></view>
        </view>
        <view class="lm-stepper-label">神游古迹 · 第{{landmarkIdx + 1}}问</view>

        <view class="lm-quiz-card lm-card-stacked fade-in" wx:if="{{landmarkQuestions[landmarkIdx]}}">
          <view class="lm-question">{{landmarkQuestions[landmarkIdx].content}}</view>

          <view class="lm-options">
            <view
              class="lm-opt {{landmarkShowResult ? (idx === landmarkQuestions[landmarkIdx].correct_index ? 'lm-correct' : (idx === landmarkAnswers[landmarkAnswers.length - 1].userIdx ? 'lm-wrong' : '')) : ''}}"
              wx:for="{{landmarkQuestions[landmarkIdx].options}}"
              wx:key="*this"
              wx:for-index="idx"
              bindtap="selectLandmarkAnswer"
              data-idx="{{idx}}"
            >
              <text class="lm-opt-key">{{['A','B','C'][idx]}}</text>
              <text>{{item}}</text>
              <text class="lm-opt-icon" wx:if="{{landmarkShowResult}}">{{idx === landmarkQuestions[landmarkIdx].correct_index ? ' ✓' : (idx === landmarkAnswers[landmarkAnswers.length - 1].userIdx ? ' ✗' : '')}}</text>
            </view>
          </view>

          <view class="lm-hint">
            <text>💡 答对 2 题即可获得现世药材奖励</text>
          </view>

          <view class="lm-explanation" wx:if="{{landmarkShowResult}}">
            <view class="lm-explanation-dot {{landmarkAnswers[landmarkAnswers.length - 1].correct ? 'lm-exp-correct' : 'lm-exp-wrong'}}"></view>
            <text>{{landmarkQuestions[landmarkIdx].explanation}}</text>
          </view>

          <button
            class="lm-next-btn"
            wx:if="{{landmarkShowResult && !landmarkAnswers[landmarkAnswers.length - 1].correct}}"
            bindtap="nextLandmarkQuestion"
          >{{landmarkIdx < 2 ? '下一题' : '查看结果'}}</button>
        </view>

        <view class="lm-watermark">神游</view>
      </block>

      <!-- 结算结果 -->
      <view class="lm-result" wx:else>
        <view class="lm-stamp {{landmarkResult.is_pass ? 'lm-stamp-pass' : 'lm-stamp-fail'}}">
          <text>{{landmarkResult.is_pass ? '吉' : '憾'}}</text>
        </view>
        <view class="lm-result-status">{{landmarkResult.is_pass ? '通关成功' : '未能通过'}}</view>
        <view class="lm-result-score">答对 <text class="lm-score-num">{{landmarkResult.score}}</text> / 3 题</view>

        <view class="lm-result-cost">消耗灵力 <text class="lm-cost-num">{{landmarkResult.cost}}</text></view>

        <view wx:if="{{landmarkResult.rewards.length > 0}}" class="lm-reward-card lm-reward-glow">
          <view class="lm-reward-label">获得奖励</view>
          <view class="lm-reward-item" wx:for="{{landmarkResult.rewards}}" wx:key="id">
            <text class="lm-reward-tier {{item.tier}}">{{item.tier}}</text>
            <text class="lm-reward-name">{{item.name}}</text>
          </view>
        </view>
        <view wx:else class="lm-fail-encourage">
          <text class="lm-fail-text">医理深奥，大侠请重头来过</text>
        </view>

        <button class="lm-retry-btn" bindtap="exitLandmarkQuiz">返回体质测评</button>

        <view class="lm-watermark">神游</view>
      </view>

      <view style="height: 160rpx;"></view>
    </scroll-view>
  </block>

  <!-- ═══════════ 体质辨识（原有） ═══════════ -->
  <scroll-view scroll-y class="scroll-content" wx:else>

    <view style="padding: 24rpx 24rpx 0;">
      <view class="hero fade-in">
        <view class="hero-badge">AI 九种体质辨识</view>
        <view class="hero-title">精准测评<br/><text class="highlight">专属方案</text></view>
        <view class="hero-subtitle">专业问卷 + 舌象拍照 · 双维度融合判定</view>
      </view>
    </view>

    <block wx:if="{{step !== 'result'}}">
      <view class="section-header">
        <view class="section-title">了解九种体质</view>
      </view>
      <view class="physical-types fade-in">
        <view class="physical-chip {{selectedPhysical === '平和质' ? 'active' : ''}}" bindtap="selectPhysical" data-name="平和质" data-desc="体质最佳">
          <text class="emoji">✨</text><text class="name">平和质</text>
        </view>
        <view class="physical-chip {{selectedPhysical === '气虚质' ? 'active' : ''}}" bindtap="selectPhysical" data-name="气虚质" data-desc="容易疲乏">
          <text class="emoji">😮‍💨</text><text class="name">气虚质</text>
        </view>
        <view class="physical-chip {{selectedPhysical === '阳虚质' ? 'active' : ''}}" bindtap="selectPhysical" data-name="阳虚质" data-desc="怕冷畏寒">
          <text class="emoji">🥶</text><text class="name">阳虚质</text>
        </view>
        <view class="physical-chip {{selectedPhysical === '阴虚质' ? 'active' : ''}}" bindtap="selectPhysical" data-name="阴虚质" data-desc="手足心热">
          <text class="emoji">🔥</text><text class="name">阴虚质</text>
        </view>
        <view class="physical-chip {{selectedPhysical === '痰湿质' ? 'active' : ''}}" bindtap="selectPhysical" data-name="痰湿质" data-desc="体型偏胖">
          <text class="emoji">💧</text><text class="name">痰湿质</text>
        </view>
        <view class="physical-chip {{selectedPhysical === '湿热质' ? 'active' : ''}}" bindtap="selectPhysical" data-name="湿热质" data-desc="面部油腻">
          <text class="emoji">🌡️</text><text class="name">湿热质</text>
        </view>
        <view class="physical-chip {{selectedPhysical === '血瘀质' ? 'active' : ''}}" bindtap="selectPhysical" data-name="血瘀质" data-desc="色素沉着">
          <text class="emoji">🫀</text><text class="name">血瘀质</text>
        </view>
        <view class="physical-chip {{selectedPhysical === '气郁质' ? 'active' : ''}}" bindtap="selectPhysical" data-name="气郁质" data-desc="情绪抑郁">
          <text class="emoji">😔</text><text class="name">气郁质</text>
        </view>
        <view class="physical-chip {{selectedPhysical === '特禀质' ? 'active' : ''}}" bindtap="selectPhysical" data-name="特禀质" data-desc="易过敏">
          <text class="emoji">🤧</text><text class="name">特禀质</text>
        </view>
      </view>
    </block>

    <block wx:if="{{step !== 'result'}}">
      <view class="section-header">
        <view class="section-title">开始问卷测评</view>
      </view>
    </block>

    <view class="quiz-card-wrapper fade-in">
      <view class="step-gender" wx:if="{{step === 'gender'}}">
        <view class="gender-title">精准评估需要了解您的性别</view>
        <view class="gender-options">
          <view class="gender-card" bindtap="selectGender" data-gender="male">
            <view class="gender-icon">👨</view>
            <view>男</view>
          </view>
          <view class="gender-card" bindtap="selectGender" data-gender="female">
            <view class="gender-icon">👩</view>
            <view>女</view>
          </view>
        </view>
      </view>

      <block wx:if="{{step === 'testing'}}">
        <view class="quiz-progress">
          <text class="quiz-num">第 <text style="color:var(--accent1)">{{currentIndex + 1}}</text>/{{currentQueue.length}} 题</text>
          <view class="quiz-bar-bg">
            <view class="quiz-bar-fill" style="width: {{((currentIndex + 1) / currentQueue.length) * 100}}%"></view>
          </view>
        </view>

        <view class="question-type" wx:if="{{currentQueue[currentIndex].type}}">{{currentQueue[currentIndex].type}}维度</view>
        <view class="quiz-q">{{currentQueue[currentIndex].text}}</view>

        <view class="quiz-options">
          <block wx:for="{{optionsList}}" wx:key="score">
            <view class="quiz-opt {{currentAnswer === item.score ? 'selected' : ''}}"
                  bindtap="selectOption" data-score="{{item.score}}">
              {{['A','B','C','D','E'][index]}}. {{item.label}}
            </view>
          </block>
        </view>

        <view class="action-footer">
          <button class="nav-btn prev-btn" bindtap="prevQuestion" wx:if="{{currentIndex > 0}}">上一题</button>
        </view>
      </block>

      <view class="step-intermission" wx:if="{{step === 'intermission'}}">
        <view class="intermission-title">基础筛查已完成</view>
        <view class="intermission-desc">系统已为您初步锁定体质倾向。是否继续完成进阶测试（约2分钟），以获取最专业的综合调理方案？</view>
        <button class="nav-btn submit-btn" bindtap="startAdvancedMode">继续进阶测试 (推荐)</button>
        <button class="nav-btn prev-btn" style="margin-top:24rpx; width: 100%" bindtap="generateFinalReport">直接查看基础报告</button>
      </view>

      <!-- 结果展示 -->
      <view class="step-result" wx:if="{{step === 'result'}}">
        <view class="result-header">
          <view class="result-emoji">{{resultData.majorEmoji}}</view>
          <view class="result-type">{{resultData.majorName}}</view>
          <view class="result-score">转化分 <text class="highlight">{{resultData.majorScore}}</text></view>
          <view class="result-date">测评日期：{{resultData.date}}</view>
        </view>

        <view class="result-tip">
          <view class="tip-title">📋 体质分析</view>
          <view class="tip-text">{{resultData.tip}}</view>
        </view>

        <view class="result-tie-warn" wx:if="{{resultData.tieNote}}">
          <view class="tie-icon">⚠️</view>
          <view class="tie-text">{{resultData.tieNote}}</view>
        </view>

        <view class="result-details">
          <view class="details-title">九种体质转化分一览</view>
          <view class="details-list">
            <view class="detail-item {{item.id === resultData.majorId ? 'highlight' : ''}}"
                  wx:for="{{resultData.details}}" wx:key="id">
              <view class="detail-emoji">{{item.emoji}}</view>
              <view class="detail-name">{{item.name}}</view>
              <view class="detail-score">{{item.score}}分</view>
              <view class="detail-judgment judgment-{{item.judgment === '是' ? 'yes' : item.judgment === '倾向是' ? 'maybe' : 'no'}}">{{item.judgment}}</view>
            </view>
          </view>
        </view>

        <view class="result-actions">
          <button class="nav-btn submit-btn" bindtap="goToHealth">返回首页</button>
          <button class="nav-btn prev-btn" style="margin-top:20rpx; width: 100%" bindtap="retakeQuiz">重新测评</button>
        </view>
      </view>
    </view>

    <view class="tongue-entry fade-in" bindtap="openTongue" wx:if="{{step !== 'result'}}">
      <view class="tongue-icon">📷</view>
      <view class="tongue-title">AI 舌象拍照识别</view>
      <view class="tongue-desc">拍摄舌头照片，AI 自动分析气血湿气状况</view>
    </view>

    <view style="height: 160rpx;"></view>
  </scroll-view>
</view>
