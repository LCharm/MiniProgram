<view class="app-shell" data-theme="{{currentTheme}}">
  <view class="list" wx:if="{{!loading && !empty}}">
    <view class="card fade-in" wx:for="{{list}}" wx:key="id">
      <view class="card-header">
        <view class="c-title">{{item.name}}</view>
        <view class="c-remove" bindtap="removeCollect" data-id="{{item.id}}">取消收藏</view>
      </view>
      <view class="c-tags" wx:if="{{item.tags && item.tags.length}}">
        <text class="c-tag" wx:for="{{item.tags}}" wx:for-item="tag" wx:key="*this">{{tag}}</text>
      </view>
      <view class="c-desc">{{item.desc}}</view>
      <view class="c-row"><text class="c-label">配料：</text><text>{{item.formula}}</text></view>
      <view class="c-row"><text class="c-label">适宜：</text><text>{{item.suitable}}</text></view>
      <view class="c-row" wx:if="{{item.contraindications}}"><text class="c-label" style="color: #ff6b9d;">禁忌：</text><text>{{item.contraindications}}</text></view>
    </view>
  </view>

  <view class="empty" wx:if="{{!loading && empty}}">
    <view class="empty-icon">📭</view>
    <view class="empty-title">暂无收藏的茶方</view>
    <view class="empty-desc">去 AI 智能调配生成专属茶方并收藏吧</view>
  </view>

  <view class="loading" wx:if="{{loading}}">
    <view class="loading-text">加载中...</view>
  </view>

  <view style="height: 60rpx;"></view>
</view>
