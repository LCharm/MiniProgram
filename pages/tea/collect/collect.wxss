.app-shell { padding: 32rpx; min-height: 100vh; background: var(--bg); color: var(--text); }

.list { display: flex; flex-direction: column; gap: 24rpx; }

.card { background: var(--card); border: 2rpx solid var(--border); border-radius: var(--radius); padding: 32rpx; }
.card-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 16rpx; }
.c-title { font-size: 32rpx; font-weight: 800; color: var(--accent1); }
.c-remove { font-size: 22rpx; color: #e8878a; padding: 6rpx 20rpx; border: 1rpx solid #e8878a; border-radius: 24rpx; }

.c-tags { margin-bottom: 16rpx; }
.c-tag { display: inline-block; font-size: 20rpx; padding: 4rpx 14rpx; background: rgba(78, 205, 196, 0.1); color: var(--accent2); border-radius: 20rpx; margin-right: 12rpx; }

.c-desc { font-size: 26rpx; color: var(--text); line-height: 1.6; margin-bottom: 16rpx; }

.c-row { display: flex; font-size: 24rpx; margin-bottom: 10rpx; line-height: 1.5; }
.c-label { color: var(--text-sub); width: 80rpx; flex-shrink: 0; }

.empty { text-align: center; padding-top: 200rpx; }
.empty-icon { font-size: 80rpx; margin-bottom: 24rpx; }
.empty-title { font-size: 30rpx; font-weight: 700; color: var(--text); margin-bottom: 12rpx; }
.empty-desc { font-size: 24rpx; color: var(--text-sub); }

.loading { text-align: center; padding-top: 200rpx; }
.loading-text { font-size: 28rpx; color: var(--text-sub); }

@keyframes fadeIn { from { opacity: 0; transform: translateY(10rpx); } to { opacity: 1; transform: translateY(0); } }
.fade-in { animation: fadeIn 0.3s ease; }
