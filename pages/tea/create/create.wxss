.container { padding: 32rpx; min-height: 100vh; background: var(--bg); color: var(--text); }
.section { margin-bottom: 48rpx; }
.title { font-size: 28rpx; font-weight: 700; margin-bottom: 24rpx; color: var(--accent1); }

.grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 20rpx; }
.item { background: var(--card); border: 2rpx solid var(--border); border-radius: var(--radius); padding: 24rpx 0; display: flex; flex-direction: column; align-items: center; transition: all 0.2s; }
.item.active { background: rgba(232, 168, 56, 0.1); border-color: var(--accent1); transform: translateY(-4rpx); }
.item .icon { font-size: 48rpx; margin-bottom: 12rpx; }
.item .name { font-size: 24rpx; }
.item.active .name { color: var(--accent1); font-weight: bold; }

.chips { display: flex; flex-wrap: wrap; gap: 24rpx; }
.chip { background: var(--card); border: 2rpx solid var(--border); padding: 12rpx 36rpx; border-radius: 40rpx; font-size: 26rpx; transition: all 0.2s; color: var(--text-sub); }
.chip.active { background: rgba(78, 205, 196, 0.15); border-color: var(--accent2); color: var(--accent2); font-weight: bold; }

.action { margin-top: 60rpx; margin-bottom: 40rpx; }
.btn { background: linear-gradient(135deg, var(--accent1), #f5a623); color: #0f0f18; font-weight: 800; border-radius: 44rpx; height: 88rpx; line-height: 88rpx; font-size: 30rpx; }
.btn[disabled] { opacity: 0.7; }

.result { animation: fadeIn 0.4s ease; }
.result-card { background: linear-gradient(180deg, #1a2530 0%, #0f1520 100%); border-radius: var(--radius); padding: 40rpx; border: 2rpx solid rgba(78, 205, 196, 0.3); position: relative; }
.badge { position: absolute; top: 0; right: 0; background: var(--accent2); color: #0f0f18; font-size: 20rpx; font-weight: 700; padding: 6rpx 20rpx; border-radius: 0 var(--radius) 0 var(--radius); }
.r-title { font-size: 36rpx; font-weight: 800; color: var(--accent2); margin-bottom: 20rpx; }
.r-tags text { display: inline-block; font-size: 20rpx; padding: 4rpx 16rpx; background: rgba(78, 205, 196, 0.1); color: var(--accent2); border-radius: 20rpx; margin-right: 16rpx; margin-bottom: 24rpx; }
.r-desc { font-size: 26rpx; color: var(--text); line-height: 1.6; margin-bottom: 24rpx; }
.divider { height: 2rpx; background: rgba(255,255,255,0.05); margin-bottom: 24rpx; }
.r-row { display: flex; font-size: 24rpx; margin-bottom: 16rpx; line-height: 1.5; }
.label { color: var(--text-sub); width: 80rpx; flex-shrink: 0; }
.val { color: var(--text); flex: 1; }
@keyframes fadeIn { from { opacity: 0; transform: translateY(10rpx); } to { opacity: 1; transform: translateY(0); } }
