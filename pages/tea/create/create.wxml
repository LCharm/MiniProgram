<view class="app-shell" data-theme="{{currentTheme}}">
  <view class="section">
    <view class="title">1. 选择核心药材 (最多3种)</view>
    <view class="material-grid">
      <view class="m-chip {{item.selected ? 'active' : ''}} {{item.locked ? 'locked' : ''}}"
            wx:for="{{materials}}" wx:key="id"
            bindtap="toggleMaterial" data-id="{{item.id}}">

        <!-- 选中时的右上角勾选标识 -->
        <view class="m-check-badge" wx:if="{{item.selected}}">✓</view>

        <!-- 图片 -->
        <image class="m-icon-img" src="{{item.icon_url}}" mode="aspectFit" wx:if="{{item.icon_url}}"></image>
        <image class="m-icon-img" src="/images/herbs/{{item.id}}.png" mode="aspectFit" wx:else></image>

        <!-- 描述文字 -->
        <view class="m-desc">{{item.locked ? item.unlock_tips || '需解锁后使用' : item.desc}}</view>
      </view>
    </view>
  </view>

  <view class="section">
    <view class="title">2. 针对季节</view>
    <view class="chips">
      <view class="chip {{season === item.val ? 'active' : ''}}"
            wx:for="{{seasons}}" wx:key="val"
            bindtap="setSeason" data-val="{{item.val}}">{{item.label}}</view>
    </view>
  </view>

  <view class="section">
    <view class="title">3. 适用人群</view>
    <view class="chips">
      <view class="chip {{crowd === item ? 'active' : ''}}"
            wx:for="{{crowds}}" wx:key="*this"
            bindtap="setCrowd" data-val="{{item}}">{{item}}</view>
    </view>
  </view>

  <view class="action">
    <button class="btn" bindtap="generate" disabled="{{loading}}">{{loading ? 'AI 深度调配中...' : '生成专属茶方'}}</button>
  </view>

  <view class="result" wx:if="{{result}}">
    <view class="result-card">
      <view class="badge">AI 生成</view>
      <view class="r-title">{{result.name}}</view>
      <view class="r-tags">
        <text wx:for="{{result.tags}}" wx:key="*this">{{item}}</text>
      </view>
      <view class="r-desc">{{result.desc}}</view>
      <view class="divider"></view>
      <view class="r-row"><text class="label">配料：</text><text class="val">{{result.formula}}</text></view>
      <view class="r-row"><text class="label">适宜：</text><text class="val">{{result.suitable}}</text></view>
      <view class="r-row" wx:if="{{result.contraindications}}">
        <text class="label" style="color: #ff6b9d;">禁忌：</text>
        <text class="val">{{result.contraindications}}</text>
      </view>
    </view>
    <view class="collect-row">
      <view class="collect-btn {{isCollected ? 'collected' : ''}}" bindtap="toggleCollect">
        <text class="collect-icon">{{isCollected ? '❤️' : '🤍'}}</text>
        <text class="collect-text">{{isCollected ? '已收藏' : '收藏茶方'}}</text>
      </view>
    </view>
  </view>
</view>
