<view class="container">
  <view class="section">
    <view class="title">1. 选择核心药材 (最多3种)</view>
    <view class="grid">
      <view class="item {{item.selected ? 'active' : ''}}" wx:for="{{materials}}" wx:key="id" bindtap="toggleMaterial" data-id="{{item.id}}">
        <view class="icon">{{item.icon}}</view>
        <view class="name">{{item.name}}</view>
      </view>
    </view>
  </view>

  <view class="section">
    <view class="title">2. 针对季节</view>
    <view class="chips">
      <view class="chip {{season === 'spring' ? 'active' : ''}}" bindtap="setSeason" data-val="spring">春季</view>
      <view class="chip {{season === 'summer' ? 'active' : ''}}" bindtap="setSeason" data-val="summer">夏季</view>
      <view class="chip {{season === 'autumn' ? 'active' : ''}}" bindtap="setSeason" data-val="autumn">秋季</view>
      <view class="chip {{season === 'winter' ? 'active' : ''}}" bindtap="setSeason" data-val="winter">冬季</view>
    </view>
  </view>

  <view class="section">
    <view class="title">3. 适用人群</view>
    <view class="chips">
      <view class="chip {{crowd === '上班族' ? 'active' : ''}}" bindtap="setCrowd" data-val="上班族">上班族</view>
      <view class="chip {{crowd === '学生党' ? 'active' : ''}}" bindtap="setCrowd" data-val="学生党">学生党</view>
      <view class="chip {{crowd === '中老年' ? 'active' : ''}}" bindtap="setCrowd" data-val="中老年">中老年</view>
      <view class="chip {{crowd === '女性调理' ? 'active' : ''}}" bindtap="setCrowd" data-val="女性调理">女性调理</view>
    </view>
  </view>

  <view class="action">
    <button class="btn" bindtap="generate" disabled="{{loading}}">{{loading ? 'AI 深度调配中...' : '生成专属茶方'}}</button>
  </view>

  <view class="result" wx:if="{{result}}">
    <view class="result-card">
      <view class="badge">AI 生成</view>
      <view class="r-title">{{result.name}}</view>
      <view class="r-tags">
        <text wx:for="{{result.tags}}" wx:key="*this">{{item}}</text>
      </view>
      <view class="r-desc">{{result.desc}}</view>
      <view class="divider"></view>
      <view class="r-row"><text class="label">配料：</text><text class="val">{{result.formula}}</text></view>
      <view class="r-row"><text class="label">适宜：</text><text class="val">{{result.suitable}}</text></view>
    </view>
  </view>
  <view style="height: 60rpx;"></view>
</view>
