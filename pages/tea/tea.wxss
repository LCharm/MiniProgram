.scroll-content {
  height: 100vh;
  padding-bottom: 200rpx;
  background: var(--bg, #0f0f18);
}

/* ===== 顶部导航 ===== */
.sub-nav {
  display: flex;
  justify-content: space-around;
  padding: 20rpx 24rpx;
  background: var(--card);
  border-bottom: 2rpx solid var(--border);
  position: sticky;
  top: 0;
  z-index: 10;
}
.sub-nav-pill {
  font-size: 24rpx;
  color: var(--text-sub);
  padding: 10rpx 20rpx;
  border-radius: 30rpx;
  transition: all 0.3s;
}
.sub-nav-pill.active {
  background: rgba(232, 168, 56, 0.15);
  color: var(--accent1);
  font-weight: bold;
}

/* ===== Hero ===== */
.hero {
  border-radius: var(--radius);
  background: var(--card);
  padding: 40rpx 36rpx 32rpx;
  position: relative;
  overflow: hidden;
}
.hero::before {
  content: '';
  position: absolute;
  top: -60rpx; right: -60rpx;
  width: 240rpx; height: 240rpx;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(232,168,56,0.3), transparent);
}
.hero-badge {
  display: inline-block;
  background: var(--accent1);
  color: #0f0f18;
  font-size: 20rpx;
  font-weight: 700;
  padding: 4rpx 20rpx;
  border-radius: 40rpx;
  margin-bottom: 20rpx;
}
.hero-title { font-size: 44rpx; font-weight: 800; line-height: 1.3; }
.highlight { color: var(--accent1); }
.hero-subtitle { font-size: 22rpx; color: var(--text-sub); margin-top: 12rpx; }

.hero-stats {
  display: flex;
  gap: 40rpx;
  margin-top: 24rpx;
  padding-top: 24rpx;
  border-top: 1rpx solid var(--border);
}
.stat-item { text-align: center; }
.stat-num { font-size: 36rpx; font-weight: 800; color: var(--accent1); }
.stat-label { font-size: 20rpx; color: var(--text-sub); margin-top: 4rpx; }

.hero-formula { background: var(--card); }
.hero-game { background: var(--card); }
.hero-contest { background: var(--card); }

/* ===== 标题样式 ===== */
.section-header { display: flex; align-items: center; justify-content: space-between; padding: 28rpx 24rpx 16rpx; }
.section-title { font-size: 30rpx; font-weight: 700; display: flex; align-items: center; gap: 12rpx; }
.section-title::before { content: ''; display: block; width: 6rpx; height: 32rpx; background: var(--accent1); border-radius: 4rpx; }
.section-more { font-size: 24rpx; color: var(--accent1); }

/* ===== 症状标签 ===== */
.symptom-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
  padding: 0 24rpx 20rpx;
}
.symptom-tag {
  font-size: 24rpx;
  padding: 12rpx 24rpx;
  background: var(--card);
  border: 2rpx solid var(--border);
  border-radius: 40rpx;
  color: var(--text-sub);
  transition: all 0.2s;
}
.symptom-tag.active {
  background: rgba(232, 168, 56, 0.15);
  border-color: var(--accent1);
  color: var(--accent1);
  font-weight: bold;
}

/* ===== 茶方卡片 ===== */
.tea-formula-card {
  background: var(--card);
  margin: 0 24rpx 20rpx;
  border-radius: var(--radius);
  padding: 32rpx;
  border: 2rpx solid var(--border);
}
.tea-formula-card.accent {
  background: var(--card);
  border-color: var(--border);
}

.formula-header { display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 20rpx; }
.formula-name {
  font-size: 34rpx;
  font-weight: 800;
  color: var(--text);
  margin-bottom: 6rpx;
}
.formula-name.accent { color: var(--accent4, #a855f7); }
.formula-suit { font-size: 22rpx; color: var(--text-sub); }
.formula-badge {
  font-size: 22rpx;
  font-weight: 700;
  padding: 4rpx 16rpx;
  background: rgba(232, 168, 56, 0.15);
  color: var(--accent1);
  border-radius: 20rpx;
  flex-shrink: 0;
}
.formula-badge.accent {
  background: rgba(168,85,247,0.2);
  color: var(--accent4, #a855f7);
}

.formula-ingredients {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-bottom: 20rpx;
}
.formula-ing {
  font-size: 22rpx;
  padding: 6rpx 16rpx;
  background: var(--surface);
  border: 1rpx solid var(--border);
  border-radius: 20rpx;
  color: var(--text);
}
.formula-ing.accent {
  color: var(--accent4, #c4a8e6);
  background: rgba(168,85,247,0.1);
  border-color: rgba(168,85,247,0.2);
}

.formula-brew {
  font-size: 22rpx;
  color: var(--text-sub);
  line-height: 1.8;
  padding-top: 20rpx;
  border-top: 1rpx solid var(--border);
  white-space: pre-line;
}
.formula-brew.accent { border-top-color: rgba(168,85,247,0.15); }
.brew-label { color: var(--accent1); font-weight: 600; }
.brew-label.accent { color: var(--accent4, #a855f7); }

/* ===== AI配茶 ===== */
.material-workshop {
  background: var(--card);
  margin: 24rpx;
  border-radius: var(--radius);
  padding: 32rpx 24rpx;
  border: 2rpx solid rgba(78, 205, 196, 0.15);
}
.workshop-title {
  font-size: 26rpx;
  font-weight: 700;
  margin-bottom: 24rpx;
  color: var(--text);
}

.materials-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 20rpx;
}
.material-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 20rpx 8rpx;
  background: var(--surface);
  border: 2rpx solid transparent;
  border-radius: 16rpx;
  transition: all 0.2s;
}
.material-item.active {
  background: rgba(78, 205, 196, 0.1);
  border-color: var(--accent2);
}
.material-icon {
  font-size: 40rpx;
  margin-bottom: 8rpx;
}
.material-name { font-size: 22rpx; color: var(--text); }
.material-item.active .material-name { color: var(--accent2); font-weight: bold; }

.action-area {
  padding: 0 32rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
  margin-top: 10rpx;
}
.selected-count {
  font-size: 26rpx;
  color: var(--text-sub);
}
.generate-btn {
  margin: 0;
  background: linear-gradient(135deg, var(--accent2), #3aafa9);
  color: #0f0f18;
  font-weight: 800;
  border-radius: 40rpx;
  width: 100% !important;
  font-size: 28rpx;
  height: 80rpx;
  line-height: 1;
  padding: 0;
  display: flex;
  align-items: center;
  justify-content: center;
}
.generate-btn.disabled {
  background: var(--card);
  color: var(--text-sub);
  opacity: 0.7;
}

.recipe-result { padding: 40rpx 32rpx; }
.recipe-card {
  background: var(--card);
  border-radius: var(--radius);
  padding: 40rpx;
  border: 2rpx solid rgba(78, 205, 196, 0.3);
  position: relative;
}
.recipe-badge {
  position: absolute;
  top: 0; right: 0;
  background: var(--accent2);
  color: #0f0f18;
  font-size: 20rpx;
  font-weight: 700;
  padding: 6rpx 20rpx;
  border-radius: 0 var(--radius) 0 var(--radius);
}
.recipe-name { font-size: 36rpx; font-weight: 800; color: var(--accent2); margin-bottom: 16rpx; }
.recipe-tags { display: flex; gap: 12rpx; margin-bottom: 24rpx; }
.tag { font-size: 20rpx; padding: 4rpx 16rpx; background: rgba(78, 205, 196, 0.1); color: var(--accent2); border-radius: 20rpx; }
.recipe-desc { font-size: 26rpx; color: var(--text); line-height: 1.6; margin-bottom: 32rpx; }
.recipe-divider { height: 2rpx; background: var(--border); margin-bottom: 24rpx; }
.detail-row { display: flex; font-size: 24rpx; margin-bottom: 12rpx; line-height: 1.5; }
.label { color: var(--text-sub); width: 120rpx; flex-shrink: 0; }
.value { color: var(--text); flex: 1; }
.save-btn {
  margin-top: 32rpx;
  background: var(--surface);
  color: var(--accent1);
  border: 2rpx solid var(--accent1);
  border-radius: 40rpx;
  font-size: 28rpx;
  height: 80rpx;
  line-height: 1;
  padding: 0;
  display: flex;
  align-items: center;
  justify-content: center;
}
.save-btn.collected {
  background: rgba(107, 203, 119, 0.15);
  color: var(--green);
  border-color: var(--green);
}

/* ===== 消消乐 ===== */
.game-panel {
  background: var(--card);
  margin: 24rpx;
  border-radius: var(--radius);
  padding: 24rpx;
  border: 2rpx solid var(--border);
}

.game-stats {
  display: flex;
  justify-content: space-between;
  margin-bottom: 20rpx;
  padding: 0 8rpx;
}
.game-stat { display: flex; flex-direction: column; align-items: center; }
.gs-label { font-size: 22rpx; color: var(--text-sub); margin-bottom: 4rpx; }
.gs-val { font-size: 32rpx; font-weight: 800; color: var(--accent1); }
.gs-val.urgent { color: #ff6b6b; animation: pulse 0.5s infinite alternate; }

@keyframes pulse {
  from { opacity: 1; }
  to { opacity: 0.5; }
}

.game-board {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 16rpx;
  padding: 0 4rpx;
  perspective: 1000px;
}
.card-wrap {
  aspect-ratio: 3/4;
  position: relative;
}
.card {
  width: 100%; height: 100%;
  position: relative;
  transition: transform 0.5s;
  transform-style: preserve-3d;
}
.card.flipped { transform: rotateY(180deg); }
.card-face {
  position: absolute;
  width: 100%; height: 100%;
  backface-visibility: hidden;
  border-radius: 10rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}
.card-back {
  background: linear-gradient(135deg, var(--card), var(--bg));
  border: 2rpx solid var(--border);
  background-image: repeating-linear-gradient(45deg, transparent, transparent 10px, var(--border) 10px, var(--border) 20px);
}
.card-front {
  background: rgba(232, 168, 56, 0.1);
  border: 2rpx solid var(--accent1);
  transform: rotateY(180deg);
}
.card-front.matched {
  background: rgba(107, 203, 119, 0.2);
  border-color: var(--green);
  opacity: 0.6;
}
.card-icon { font-size: 44rpx; margin-bottom: 6rpx; }
.card-name { font-size: 20rpx; font-weight: bold; color: var(--text); }

.game-start-btn {
  margin: 24rpx auto 0;
  background: linear-gradient(135deg, var(--green), #3aafa9);
  color: #0f0f18;
  font-weight: 800;
  font-size: 26rpx;
  border-radius: 40rpx;
  width: 80% !important;
  height: 72rpx;
  line-height: 1;
  padding: 0;
  display: flex;
  align-items: center;
  justify-content: center;
}
.game-tips { text-align: center; font-size: 22rpx; color: var(--text-sub); margin-top: 20rpx; }

/* ===== 奖励卡片 ===== */
.reward-card {
  margin: 24rpx;
  background: var(--card);
  border-radius: var(--radius);
  padding: 28rpx;
  border: 2rpx solid var(--border);
  text-align: center;
}
.reward-icon { font-size: 52rpx; margin-bottom: 8rpx; }
.reward-title { font-size: 28rpx; font-weight: 700; margin-bottom: 6rpx; }
.reward-desc { font-size: 22rpx; color: var(--text-sub); margin-bottom: 20rpx; }
.reward-tiers { display: flex; gap: 16rpx; justify-content: center; }
.reward-tier {
  font-size: 22rpx;
  padding: 10rpx 24rpx;
  border-radius: 20rpx;
  border: 2rpx solid var(--border);
  color: var(--text-sub);
}
.reward-tier.green {
  background: rgba(107, 203, 119, 0.1);
  border-color: rgba(107, 203, 119, 0.2);
  color: var(--green);
}
.reward-tier.gold {
  background: rgba(232, 168, 56, 0.1);
  border-color: rgba(232, 168, 56, 0.2);
  color: var(--accent1);
}
.reward-tier.earned {
  border-color: currentColor;
  font-weight: bold;
}

/* ===== 创意赛 ===== */
.contest-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 16rpx;
  padding: 0 24rpx;
}
.contest-card {
  background: var(--card);
  border: 2rpx solid var(--border);
  border-radius: var(--radius);
  padding: 28rpx 20rpx;
  text-align: center;
  position: relative;
  transition: all 0.2s;
}
.contest-card.hot {
  border-color: rgba(232, 168, 56, 0.3);
}
.contest-card:active { transform: scale(0.96); }
.contest-icon { font-size: 52rpx; margin-bottom: 12rpx; }
.contest-name { font-size: 26rpx; font-weight: 800; color: var(--text); margin-bottom: 6rpx; }
.contest-author { font-size: 20rpx; color: var(--text-sub); margin-bottom: 4rpx; }
.contest-likes { font-size: 22rpx; color: var(--accent1); }
.contest-hot-badge {
  position: absolute;
  top: 8rpx; right: 8rpx;
  background: linear-gradient(135deg, #ff6b6b, var(--accent1));
  color: #fff;
  font-size: 18rpx;
  font-weight: 700;
  padding: 2rpx 12rpx;
  border-radius: 20rpx;
}

.submit-section { padding: 30rpx 24rpx; }
.submit-formula-btn {
  margin: 0;
  background: linear-gradient(135deg, #a855f7, #7c3aed);
  color: #fff;
  font-weight: 800;
  font-size: 28rpx;
  border-radius: 40rpx;
  width: 100% !important;
  height: 80rpx;
  line-height: 1;
  padding: 0;
  display: flex;
  align-items: center;
  justify-content: center;
}

/* ===== 优惠券弹窗 ===== */
.coupon-overlay {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0.7);
  z-index: 999;
  display: flex;
  align-items: center;
  justify-content: center;
}
.coupon-modal {
  background: var(--card);
  border: 2rpx solid var(--border);
  border-radius: var(--radius);
  padding: 48rpx 40rpx;
  margin: 0 60rpx;
  text-align: center;
  width: 80%;
}
.coupon-emoji { font-size: 72rpx; margin-bottom: 16rpx; }
.coupon-title { font-size: 36rpx; font-weight: 800; color: var(--accent1); margin-bottom: 12rpx; }
.coupon-score { font-size: 28rpx; color: var(--text); margin-bottom: 16rpx; }
.coupon-reward { font-size: 36rpx; font-weight: 800; color: var(--accent1); margin-bottom: 12rpx; }
.coupon-desc { font-size: 24rpx; color: var(--text-sub); margin-bottom: 32rpx; }
.coupon-btn {
  margin: 0;
  background: var(--accent1);
  color: #0f0f18;
  font-weight: 800;
  font-size: 30rpx;
  border-radius: 40rpx;
  width: 100% !important;
  height: 80rpx;
  line-height: 1;
  padding: 0;
  display: flex;
  align-items: center;
  justify-content: center;
}
