/* components/box/box.wxss — 每日盲盒动画样式 */

/* ===== 盲盒主体 ===== */
.box-root { width: 100%; }

.box-trigger {
  position: relative;
  background: linear-gradient(145deg, var(--card), var(--surface));
  border: 3rpx solid var(--border);
  border-radius: 24rpx;
  padding: 28rpx 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  overflow: hidden;
  transition: border-color 0.3s;
}

.box-ribbon {
  position: absolute;
  top: -6rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 80rpx;
  height: 18rpx;
  background: var(--accent1);
  border-radius: 0 0 10rpx 10rpx;
}

.box-body {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 10rpx;
  position: relative;
  z-index: 1;
}

.box-icon { font-size: 64rpx; transition: transform 0.2s; }

.box-label {
  font-size: 26rpx;
  font-weight: 700;
  color: var(--accent1);
}

.box-trigger.opened {
  opacity: 0.55;
  pointer-events: auto;
}
.box-trigger.opened .box-label { color: var(--text-sub); }

/* ===== 粒子光点 ===== */
.box-sparkle { position: absolute; inset: 0; pointer-events: none; }
.sparkle-dot {
  position: absolute;
  width: 10rpx;
  height: 10rpx;
  border-radius: 50%;
  background: var(--accent1);
  opacity: 0;
  animation: sparkleFloat 1.2s ease-out infinite;
}
.sparkle-dot.s1 { top: 20%; left: 18%; animation-delay: 0s; }
.sparkle-dot.s2 { top: 10%; left: 45%; animation-delay: 0.2s; }
.sparkle-dot.s3 { top: 25%; right: 18%; animation-delay: 0.4s; }
.sparkle-dot.s4 { bottom: 20%; left: 15%; animation-delay: 0.6s; }
.sparkle-dot.s5 { bottom: 15%; right: 22%; animation-delay: 0.8s; }
.sparkle-dot.s6 { bottom: 30%; left: 50%; animation-delay: 0.3s; }

@keyframes sparkleFloat {
  0% { opacity: 0; transform: translateY(0) scale(0.5); }
  30% { opacity: 1; }
  100% { opacity: 0; transform: translateY(-60rpx) scale(1.2); }
}

/* ===== 晃动动画 ===== */
.box-trigger.shaking {
  animation: shake 0.6s ease-in-out infinite;
}

@keyframes shake {
  0%, 100% { transform: translateX(0) rotate(0); }
  10%  { transform: translateX(-14rpx) rotate(-3deg); }
  20%  { transform: translateX(14rpx) rotate(3deg); }
  30%  { transform: translateX(-14rpx) rotate(-3deg); }
  40%  { transform: translateX(14rpx) rotate(3deg); }
  50%  { transform: translateX(-10rpx) rotate(-2deg); }
  60%  { transform: translateX(10rpx) rotate(2deg); }
  70%  { transform: translateX(-6rpx) rotate(-1deg); }
  80%  { transform: translateX(6rpx) rotate(1deg); }
  90%  { transform: translateX(-3rpx) rotate(0); }
}

/* ===== 金色呼吸光 ===== */
.box-trigger.glowing {
  border-color: var(--accent1);
  animation: shake 0.6s ease-in-out infinite, glow 1s ease-in-out infinite;
}

@keyframes glow {
  0%, 100% { box-shadow: 0 0 24rpx rgba(205, 168, 105, 0.25); }
  50%      { box-shadow: 0 0 64rpx rgba(205, 168, 105, 0.7), 0 0 100rpx rgba(205, 168, 105, 0.3); }
}

/* ===== 弹窗遮罩 ===== */
.modal-overlay {
  position: fixed;
  inset: 0;
  z-index: 999;
  background: rgba(0, 0, 0, 0.65);
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 60rpx;
}

/* ===== 弹窗卡片 ===== */
.modal-card {
  width: 100%;
  max-width: 560rpx;
  background: var(--card);
  border-radius: 28rpx;
  border: 2rpx solid var(--border);
  padding: 48rpx 36rpx 36rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.modal-card.pop-in { animation: popIn 0.45s cubic-bezier(0.34, 1.56, 0.64, 1); }

@keyframes popIn {
  0%   { transform: scale(0.4); opacity: 0; }
  70%  { transform: scale(1.06); }
  100% { transform: scale(1); opacity: 1; }
}

/* ===== 通用按钮 ===== */
.modal-btn {
  margin-top: 36rpx;
  width: 100%;
  height: 80rpx;
  line-height: 80rpx;
  text-align: center;
  border-radius: 40rpx;
  font-size: 28rpx;
  font-weight: 700;
  background: var(--accent1);
  color: #1a1412;
}

.modal-btn.primary { background: var(--accent1); }

.modal-btn-ghost {
  margin-top: 16rpx;
  width: 100%;
  height: 72rpx;
  line-height: 72rpx;
  text-align: center;
  border-radius: 40rpx;
  font-size: 24rpx;
  color: var(--text-sub);
  background: transparent;
  border: 2rpx solid var(--border);
}

/* ===== herb 图鉴卡片 ===== */
.result-herb {
  position: relative;
  width: 240rpx;
  height: 320rpx;
  perspective: 800rpx;
  margin-bottom: 16rpx;
}

.herb-glow-ring {
  position: absolute;
  inset: -20rpx;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(205, 168, 105, 0.25) 0%, transparent 70%);
  animation: herbGlowPulse 2s ease-in-out infinite;
}

@keyframes herbGlowPulse {
  0%, 100% { opacity: 0.5; transform: scale(0.95); }
  50%      { opacity: 1; transform: scale(1.05); }
}

.herb-card-body {
  position: relative;
  z-index: 1;
  width: 100%;
  height: 100%;
  background: linear-gradient(160deg, #2a2018, #1a1412);
  border: 3rpx solid var(--accent1);
  border-radius: 20rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  animation: cardFlipIn 0.8s cubic-bezier(0.34, 1.56, 0.64, 1);
}

@keyframes cardFlipIn {
  0%   { transform: rotateY(90deg); opacity: 0; }
  100% { transform: rotateY(0); opacity: 1; }
}

.herb-emblem { font-size: 80rpx; }

.herb-tier-tag {
  font-size: 20rpx;
  font-weight: 700;
  color: #1a1412;
  background: var(--accent1);
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
}

.herb-name {
  font-size: 28rpx;
  font-weight: 800;
  color: var(--accent1);
  text-align: center;
}

.herb-sub {
  font-size: 20rpx;
  color: var(--text-sub);
}

/* ===== voucher 票根 ===== */
.result-voucher {
  width: 100%;
  display: flex;
  align-items: stretch;
  margin-bottom: 8rpx;
}

.voucher-stub {
  width: 16rpx;
  flex-shrink: 0;
  background: repeating-linear-gradient(
    to bottom,
    transparent,
    transparent 10rpx,
    var(--bg) 10rpx,
    var(--bg) 16rpx
  );
}

.voucher-body {
  flex: 1;
  background: linear-gradient(160deg, #b85440, #8b3020);
  border-radius: 0 16rpx 16rpx 0;
  padding: 36rpx 32rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
  position: relative;
  overflow: hidden;
}

/* 票根顶部半圆镂空 */
.voucher-body::before {
  content: '';
  position: absolute;
  top: -18rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 36rpx;
  height: 36rpx;
  border-radius: 50%;
  background: var(--card);
}

.voucher-body::after {
  content: '';
  position: absolute;
  bottom: -18rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 36rpx;
  height: 36rpx;
  border-radius: 50%;
  background: var(--card);
}

.voucher-seal {
  font-size: 32rpx;
  font-weight: 900;
  color: rgba(255, 220, 180, 0.6);
  border: 3rpx solid rgba(255, 220, 180, 0.4);
  border-radius: 8rpx;
  padding: 6rpx 16rpx;
  letter-spacing: 8rpx;
}

.voucher-title {
  font-size: 22rpx;
  color: rgba(255, 220, 180, 0.8);
  font-weight: 600;
}

.voucher-name {
  font-size: 30rpx;
  font-weight: 800;
  color: #ffe0c0;
  text-align: center;
}

.voucher-code {
  font-size: 20rpx;
  color: rgba(255, 220, 180, 0.5);
  font-family: monospace;
  letter-spacing: 2rpx;
}

.voucher-hint {
  font-size: 20rpx;
  color: rgba(255, 220, 180, 0.55);
  margin-top: 8rpx;
}

/* ===== spirit 灵力球 ===== */
.result-spirit {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 20rpx;
  margin-bottom: 8rpx;
}

.spirit-orb {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  background: radial-gradient(circle at 40% 35%, rgba(205, 168, 105, 0.5), rgba(30, 20, 10, 0.9));
  box-shadow: 0 0 60rpx rgba(205, 168, 105, 0.5), 0 0 120rpx rgba(205, 168, 105, 0.2);
  display: flex;
  align-items: center;
  justify-content: center;
  animation: orbFloat 3s ease-in-out infinite;
}

@keyframes orbFloat {
  0%, 100% { transform: translateY(0); }
  50%      { transform: translateY(-12rpx); }
}

.spirit-inner {
  font-size: 56rpx;
}

.spirit-name {
  font-size: 32rpx;
  font-weight: 800;
  color: var(--accent1);
}

.spirit-remain {
  font-size: 22rpx;
  color: var(--text-sub);
}

/* ===== retry 再抽一次 ===== */
.result-retry {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 8rpx;
}

.retry-icon {
  font-size: 80rpx;
  animation: retrySpin 1.5s linear infinite;
}

@keyframes retrySpin {
  from { transform: rotate(0deg); }
  to   { transform: rotate(360deg); }
}

.retry-title {
  font-size: 30rpx;
  font-weight: 700;
  color: var(--accent2);
}

.retry-desc {
  font-size: 22rpx;
  color: var(--text-sub);
}

/* ===== empty 谢谢参与 ===== */
.result-empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 8rpx;
}

.empty-leaf {
  font-size: 80rpx;
  animation: leafFall 2.5s ease-in-out infinite;
}

@keyframes leafFall {
  0%   { transform: translateY(-16rpx) rotate(0deg); opacity: 0.6; }
  25%  { transform: translateY(6rpx) rotate(12deg); opacity: 1; }
  50%  { transform: translateY(-4rpx) rotate(-8deg); opacity: 0.8; }
  75%  { transform: translateY(10rpx) rotate(6deg); opacity: 1; }
  100% { transform: translateY(-16rpx) rotate(0deg); opacity: 0.6; }
}

.empty-title {
  font-size: 30rpx;
  font-weight: 700;
  color: var(--text-sub);
}

.empty-zen {
  font-size: 24rpx;
  color: var(--text-sub);
  text-align: center;
  line-height: 1.6;
  opacity: 0.7;
}
