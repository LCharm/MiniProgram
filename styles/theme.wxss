/* styles/theme.wxss — 通过 data-theme 属性挂载 CSS 变量 */
/* 页面 .app-shell 和 自定义 TabBar .bottom-nav 需同时覆盖 */

/* 1. 暖金棕深色版 (默认) */
.app-shell[data-theme="warm"],
.bottom-nav[data-theme="warm"] {
  --bg: #1a1412;
  --surface: #261d19;
  --card: #302621;
  --text: #e8ded1;
  --text-sub: #9e8e7c;
  --border: rgba(212, 175, 111, 0.15);
  --accent1: #B87333;
  --sandalwood: #5C3A21;
  --paper: #F4EFE6;
  --accent2: #658266;
  --accent3: #b85440;
  --accent4: #6b5c7d;
  --green: #71985a;
  color: var(--text);
}

/* 2. 白天浅色版 */
.app-shell[data-theme="day"],
.bottom-nav[data-theme="day"] {
  --bg: #f2efe8;
  --surface: #faf9f6;
  --card: #ffffff;
  --accent1: #c88828;
  --accent2: #4ecdc4;
  --accent3: #ff6b9d;
  --accent4: #a855f7;
  --text: #2c2c2c;
  --text-sub: #666666;
  --border: rgba(200, 136, 40, 0.15);
  --green: #6bcb77;
  color: var(--text);
}
