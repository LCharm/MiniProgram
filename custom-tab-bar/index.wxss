@import '../styles/theme.wxss';

.bottom-nav {
  display: flex;
  background: var(--surface, #1a1a2e);
  border-top: 1px solid var(--border, rgba(232, 168, 56, 0.2));
  padding-bottom: env(safe-area-inset-bottom);
  height: 110rpx;
  box-sizing: content-box;
}
.nav-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  font-size: 20rpx;
  color: var(--text-sub, #a89880);
  transition: all 0.2s;
}
.nav-item.active {
  color: var(--accent1, #e8a838);
}
.nav-icon {
  font-size: 40rpx;
  margin-bottom: 4rpx;
}
